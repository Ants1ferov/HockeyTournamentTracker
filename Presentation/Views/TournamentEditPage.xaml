<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.TournamentEditPage"
             Title="{x:Static res:AppResources.NewTournament}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{x:Static res:AppResources.TournamentName}" />
            <Entry Text="{Binding Name}" Placeholder="{x:Static res:AppResources.TournamentNamePlaceholder}" />

            <Label Text="{x:Static res:AppResources.Description}" />
            <Editor Text="{Binding Description}" AutoSize="TextChanges" />

            <Label Text="{x:Static res:AppResources.StartDate}" />
            <DatePicker Date="{Binding StartDate}" />

            <Label Text="{x:Static res:AppResources.EndDate}" />
            <DatePicker Date="{Binding EndDate}" />

            <Label Text="{x:Static res:AppResources.RulesScoringTitle}"
                   FontAttributes="Bold"
                   FontSize="16"
                   Margin="0,16,0,0" />
            <Label Text="{x:Static res:AppResources.PointsWinReg}" />
            <Entry Text="{Binding PointsRegWin}" Keyboard="Numeric" />
            <Label Text="{x:Static res:AppResources.PointsWinOt}" />
            <Entry Text="{Binding PointsOtWin}" Keyboard="Numeric" />
            <Label Text="{x:Static res:AppResources.PointsWinSo}" />
            <Entry Text="{Binding PointsSoWin}" Keyboard="Numeric" />
            <Label Text="{x:Static res:AppResources.PointsLossReg}" />
            <Entry Text="{Binding PointsRegLoss}" Keyboard="Numeric" />
            <Label Text="{x:Static res:AppResources.PointsLossOt}" />
            <Entry Text="{Binding PointsOtLoss}" Keyboard="Numeric" />
            <Label Text="{x:Static res:AppResources.PointsLossSo}" />
            <Entry Text="{Binding PointsSoLoss}" Keyboard="Numeric" />

            <Button Text="{x:Static res:AppResources.Save}"
                    Margin="0,16,0,0"
                    Clicked="OnSaveClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

