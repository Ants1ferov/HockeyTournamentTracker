<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HockeyTournamentTracker.Presentation.Views.TournamentEditPage"
             Title="Новый турнир">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="Название турнира" />
            <Entry Text="{Binding Name}" Placeholder="Например, КХЛ 2024/25" />

            <Label Text="Описание" />
            <Editor Text="{Binding Description}" AutoSize="TextChanges" />

            <Label Text="Дата начала" />
            <DatePicker Date="{Binding StartDate}" />

            <Label Text="Дата окончания" />
            <DatePicker Date="{Binding EndDate}" />

            <Button Text="Сохранить"
                    Margin="0,16,0,0"
                    Clicked="OnSaveClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

