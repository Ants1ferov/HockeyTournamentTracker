<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.MatchEditPage"
             Title="{x:Static res:AppResources.NewMatch}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Табло матча -->
            <Border Padding="16,14" Style="{StaticResource CardElevatedStyle}">
                <VerticalStackLayout Spacing="12">
                    <!-- Подзаголовок: дата · турнир -->
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Label Text="{Binding HeaderDateText}"
                               FontSize="13"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding CompetitionTitle}"
                               FontSize="12"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                    </VerticalStackLayout>

                    <!-- Центр: команды и счёт -->
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                        <!-- Хозяева -->
                        <VerticalStackLayout Grid.Column="0" Spacing="6" HorizontalOptions="Center">
                            <Border WidthRequest="72" HeightRequest="72"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 36"
                                    HorizontalOptions="Center"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}">
                                <Grid>
                                    <Image Aspect="AspectFill"
                                           Source="{Binding HomeTeam.IconPath, Converter={StaticResource PathToImageSource}}" />
                                    <Label Text="Выбор"
                                           IsVisible="{Binding HomeTeam, Converter={StaticResource NotNullToBool}, ConverterParameter=Invert}"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"
                                           FontSize="11" />
                                </Grid>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSelectHomeTeamClicked" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Label Text="{Binding HomeTeam.Name}"
                                   HorizontalTextAlignment="Center"
                                   FontAttributes="Bold"
                                   FontSize="13"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding HomeResultLabel}"
                                   HorizontalTextAlignment="Center"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource ZoneOut}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding HomeIsWinner}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource StatusLive}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </VerticalStackLayout>

                        <!-- Счёт -->
                        <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                            <Label HorizontalTextAlignment="Center"
                                   FontSize="34"
                                   FontAttributes="Bold">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} : {1}">
                                        <Binding Path="HomeGoals" />
                                        <Binding Path="AwayGoals" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                            <Label Text="{Binding ScoreSuffix}"
                                   HorizontalTextAlignment="Center"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Brand}, Dark={StaticResource BrandDark}}"
                                   IsVisible="{Binding ScoreSuffix, Converter={StaticResource GroupNameToVisibility}}" />
                        </VerticalStackLayout>

                        <!-- Гости -->
                        <VerticalStackLayout Grid.Column="2" Spacing="6" HorizontalOptions="Center">
                            <Border WidthRequest="72" HeightRequest="72"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 36"
                                    HorizontalOptions="Center"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}">
                                <Grid>
                                    <Image Aspect="AspectFill"
                                           Source="{Binding AwayTeam.IconPath, Converter={StaticResource PathToImageSource}}" />
                                    <Label Text="Выбор"
                                           IsVisible="{Binding AwayTeam, Converter={StaticResource NotNullToBool}, ConverterParameter=Invert}"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"
                                           FontSize="11" />
                                </Grid>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSelectAwayTeamClicked" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Label Text="{Binding AwayTeam.Name}"
                                   HorizontalTextAlignment="Center"
                                   FontAttributes="Bold"
                                   FontSize="13"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding AwayResultLabel}"
                                   HorizontalTextAlignment="Center"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource ZoneOut}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding AwayIsWinner}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource StatusLive}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Чипы периодов -->
                    <HorizontalStackLayout Spacing="6"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding IsPeriodScoresVisible}">
                        <Border Style="{StaticResource StatusBadgeStyle}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardSurfaceMutedLight}, Dark={StaticResource CardSurfaceMutedDark}}">
                            <Label FontSize="12">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}П1 {0}:{1}">
                                        <Binding Path="P1Home" />
                                        <Binding Path="P1Away" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </Border>
                        <Border Style="{StaticResource StatusBadgeStyle}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardSurfaceMutedLight}, Dark={StaticResource CardSurfaceMutedDark}}">
                            <Label FontSize="12">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}П2 {0}:{1}">
                                        <Binding Path="P2Home" />
                                        <Binding Path="P2Away" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </Border>
                        <Border Style="{StaticResource StatusBadgeStyle}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardSurfaceMutedLight}, Dark={StaticResource CardSurfaceMutedDark}}">
                            <Label FontSize="12">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}П3 {0}:{1}">
                                        <Binding Path="P3Home" />
                                        <Binding Path="P3Away" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </Border>
                        <Border Style="{StaticResource StatusBadgeStyle}"
                                IsVisible="{Binding HasOvertime}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource BrandSurface}, Dark={StaticResource BrandSurfaceDark}}">
                            <Label FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Brand}, Dark={StaticResource BrandDark}}">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}ОТ {0}:{1}">
                                        <Binding Path="OTHome" />
                                        <Binding Path="OTAway" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="4">
                    <Label Text="{x:Static res:AppResources.Date}" />
                    <DatePicker Date="{Binding Date}" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="4">
                    <Label Text="{x:Static res:AppResources.Time}" />
                    <TimePicker Time="{Binding Time}" />
                </VerticalStackLayout>
            </Grid>

            <Label Text="Статус матча" />
            <Picker SelectedIndex="{Binding MatchStatusIndex}">
                <Picker.Items>
                    <x:String>Запланирован</x:String>
                    <x:String>В процессе</x:String>
                    <x:String>Завершён</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="{x:Static res:AppResources.Score}"
                   IsVisible="{Binding IsScoreVisible}" />
            <HorizontalStackLayout IsVisible="{Binding IsScoreVisible}">
                <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding HomeGoals}" />
                <Label Text=":" VerticalOptions="Center" />
                <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding AwayGoals}" />
            </HorizontalStackLayout>

            <Label Text="{x:Static res:AppResources.PeriodScoresTitle}"
                   FontAttributes="Bold"
                   Margin="0,12,0,0"
                   IsVisible="{Binding IsPeriodScoresVisible}" />
            <Grid ColumnDefinitions="Auto,60,60"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnSpacing="8"
                  RowSpacing="6"
                  IsVisible="{Binding IsPeriodScoresVisible}">
                <Label Grid.Row="0" Grid.Column="0" Text="Период 1" VerticalOptions="Center" />
                <Entry Grid.Row="0" Grid.Column="1" Keyboard="Numeric" Text="{Binding P1Home}" />
                <Entry Grid.Row="0" Grid.Column="2" Keyboard="Numeric" Text="{Binding P1Away}" />
                <Label Grid.Row="1" Grid.Column="0" Text="Период 2" VerticalOptions="Center" />
                <Entry Grid.Row="1" Grid.Column="1" Keyboard="Numeric" Text="{Binding P2Home}" />
                <Entry Grid.Row="1" Grid.Column="2" Keyboard="Numeric" Text="{Binding P2Away}" />
                <Label Grid.Row="2" Grid.Column="0" Text="Период 3" VerticalOptions="Center" />
                <Entry Grid.Row="2" Grid.Column="1" Keyboard="Numeric" Text="{Binding P3Home}" />
                <Entry Grid.Row="2" Grid.Column="2" Keyboard="Numeric" Text="{Binding P3Away}" />
                <HorizontalStackLayout Grid.Row="3" Grid.ColumnSpan="3" Spacing="8">
                    <Label Text="{x:Static res:AppResources.Overtime}" VerticalOptions="Center" TextColor="Red" />
                    <Switch IsToggled="{Binding HasOvertime}" VerticalOptions="Center" />
                    <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding OTHome}" IsVisible="{Binding HasOvertime}" />
                    <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding OTAway}" IsVisible="{Binding HasOvertime}" />
                </HorizontalStackLayout>
            </Grid>

            <VerticalStackLayout IsVisible="{Binding IsFinishedDetailsVisible}">
                <Label Text="{x:Static res:AppResources.HowMatchEnded}" />
                <Picker SelectedIndex="{Binding OutcomeIndex}"
                        SelectedIndexChanged="OnOutcomeChanged">
                    <Picker.Items>
                        <x:String>В основное время</x:String>
                        <x:String>В овертайме</x:String>
                        <x:String>По буллитам</x:String>
                    </Picker.Items>
                </Picker>

                <StackLayout x:Name="ShootoutPanel" IsVisible="{Binding IsShootoutVisible}">
                    <Label Text="{x:Static res:AppResources.ShootoutScore}" />
                    <HorizontalStackLayout>
                        <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding ShootoutHome}" />
                        <Label Text=":" VerticalOptions="Center" />
                        <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding ShootoutAway}" />
                    </HorizontalStackLayout>
                </StackLayout>
            </VerticalStackLayout>

            <Button Text="{x:Static res:AppResources.Save}"
                    Margin="0,16,0,0"
                    Clicked="OnSaveClicked" />

            <Border Margin="0,12,0,0"
                    Padding="12"
                    Style="{StaticResource CardElevatedStyle}"
                    IsVisible="{Binding HasHeadToHead}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Статистика противостояния (стадия)"
                           FontAttributes="Bold"
                           FontSize="14" />
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="8"
                          RowSpacing="4">
                        <Label Grid.Row="0" Grid.Column="0" Text="Матчей" FontSize="12" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding HeadToHead.Matches}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />

                        <Label Grid.Row="1" Grid.Column="0" FontSize="12">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}: побед / голы">
                                    <Binding Path="HomeTeam.Name" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Label Grid.Row="1" Grid.Column="1" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0} / {1}:{2}">
                                    <Binding Path="HeadToHead.TeamAWins" />
                                    <Binding Path="HeadToHead.TeamAGoals" />
                                    <Binding Path="HeadToHead.TeamBGoals" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>

                        <Label Grid.Row="2" Grid.Column="0" FontSize="12">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}: побед / голы">
                                    <Binding Path="AwayTeam.Name" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Label Grid.Row="2" Grid.Column="1" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0} / {1}:{2}">
                                    <Binding Path="HeadToHead.TeamBWins" />
                                    <Binding Path="HeadToHead.TeamBGoals" />
                                    <Binding Path="HeadToHead.TeamAGoals" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

