<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.MatchEditPage"
             Title="{x:Static res:AppResources.NewMatch}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{x:Static res:AppResources.HomeTeam}" />
            <Picker ItemsSource="{Binding Teams}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding HomeTeam}" />

            <Label Text="{x:Static res:AppResources.AwayTeam}" />
            <Picker ItemsSource="{Binding AwayTeamOptions}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding AwayTeam}" />

            <Label Text="{x:Static res:AppResources.Date}" />
            <DatePicker Date="{Binding Date}" />

            <Label Text="{x:Static res:AppResources.Time}" />
            <TimePicker Time="{Binding Time}" />

            <Label Text="{x:Static res:AppResources.Score}" />
            <HorizontalStackLayout>
                <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding HomeGoals}" />
                <Label Text=":" VerticalOptions="Center" />
                <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding AwayGoals}" />
            </HorizontalStackLayout>

            <Label Text="{x:Static res:AppResources.PeriodScoresTitle}"
                   FontAttributes="Bold"
                   Margin="0,12,0,0" />
            <Grid ColumnDefinitions="Auto,60,60" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                <Label Grid.Row="0" Grid.Column="0" Text="Период 1" VerticalOptions="Center" />
                <Entry Grid.Row="0" Grid.Column="1" Keyboard="Numeric" Text="{Binding P1Home}" />
                <Entry Grid.Row="0" Grid.Column="2" Keyboard="Numeric" Text="{Binding P1Away}" />
                <Label Grid.Row="1" Grid.Column="0" Text="Период 2" VerticalOptions="Center" />
                <Entry Grid.Row="1" Grid.Column="1" Keyboard="Numeric" Text="{Binding P2Home}" />
                <Entry Grid.Row="1" Grid.Column="2" Keyboard="Numeric" Text="{Binding P2Away}" />
                <Label Grid.Row="2" Grid.Column="0" Text="Период 3" VerticalOptions="Center" />
                <Entry Grid.Row="2" Grid.Column="1" Keyboard="Numeric" Text="{Binding P3Home}" />
                <Entry Grid.Row="2" Grid.Column="2" Keyboard="Numeric" Text="{Binding P3Away}" />
                <HorizontalStackLayout Grid.Row="3" Grid.ColumnSpan="3" Spacing="8">
                    <Label Text="{x:Static res:AppResources.Overtime}" VerticalOptions="Center" TextColor="Red" />
                    <Switch IsToggled="{Binding HasOvertime}" VerticalOptions="Center" />
                    <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding OTHome}" IsVisible="{Binding HasOvertime}" />
                    <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding OTAway}" IsVisible="{Binding HasOvertime}" />
                </HorizontalStackLayout>
            </Grid>

            <Label Text="{x:Static res:AppResources.HowMatchEnded}" />
            <Picker SelectedIndex="{Binding OutcomeIndex}"
                    SelectedIndexChanged="OnOutcomeChanged">
                <Picker.Items>
                    <x:String>В основное время</x:String>
                    <x:String>В овертайме</x:String>
                    <x:String>По буллитам</x:String>
                </Picker.Items>
            </Picker>

            <StackLayout x:Name="ShootoutPanel" IsVisible="{Binding IsShootoutVisible}">
                <Label Text="{x:Static res:AppResources.ShootoutScore}" />
                <HorizontalStackLayout>
                    <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding ShootoutHome}" />
                    <Label Text=":" VerticalOptions="Center" />
                    <Entry WidthRequest="60" Keyboard="Numeric" Text="{Binding ShootoutAway}" />
                </HorizontalStackLayout>
            </StackLayout>

            <Button Text="{x:Static res:AppResources.Save}"
                    Margin="0,16,0,0"
                    Clicked="OnSaveClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

