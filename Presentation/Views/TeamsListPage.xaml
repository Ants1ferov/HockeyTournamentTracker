<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             xmlns:converters="clr-namespace:HockeyTournamentTracker.Presentation.Converters"
             x:Class="HockeyTournamentTracker.Presentation.Views.TeamsListPage"
             Title="{x:Static res:AppResources.Teams}">

    <Grid RowDefinitions="Auto,*">
        <HorizontalStackLayout Grid.Row="0" Padding="16,8" Spacing="12">
            <Label Text="{x:Static res:AppResources.Teams}"
                   FontSize="20"
                   HorizontalOptions="StartAndExpand" />
            <Button Text="{x:Static res:AppResources.AddTeam}"
                    Clicked="OnAddTeamClicked" />
        </HorizontalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Teams}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="{x:Static res:AppResources.Delete}"
                                           BackgroundColor="Red"
                                           Invoked="OnDeleteTeamInvoked" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Frame Margin="12,6"
                               Padding="12"
                               HasShadow="False"
                               CornerRadius="8"
                               Style="{StaticResource CardFrameStyle}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTeamTapped" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Image Grid.Column="0"
                                       WidthRequest="40" HeightRequest="40"
                                       Source="{Binding IconPath, Converter={StaticResource PathToImageSource}}"
                                       Aspect="AspectFill" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                                    <Label Text="{Binding ShortName}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
