<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.StageDetailsPage"
             x:Name="ThisPage"
             Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <!-- Шапка стадии -->
            <VerticalStackLayout Spacing="4">
                <Label Text="{Binding Stage.Name}"
                       FontAttributes="Bold"
                       FontSize="22" />
                <Label Text="{Binding Stage.StageType, Converter={StaticResource StageTypeToString}}"
                       FontSize="14"
                       TextColor="Gray" />
            </VerticalStackLayout>

            <!-- Действия со стадией -->
            <HorizontalStackLayout Spacing="12">
                <Button Text="Редактировать стадию"
                        Clicked="OnEditStageClicked" />
                <Button Text="{x:Static res:AppResources.AddMatch}"
                        Clicked="OnAddMatchClicked" />
            </HorizontalStackLayout>

            <!-- Управление составом и группами внутри стадии -->
            <VerticalStackLayout Spacing="10">
                <Label Text="{x:Static res:AppResources.Groups}"
                       FontAttributes="Bold"
                       FontSize="16" />
                <Button Text="{x:Static res:AppResources.AddGroup}"
                        Clicked="OnAddGroupClicked" />

                <CollectionView ItemsSource="{Binding StageGroups}"
                                Margin="0,4,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8"
                                  Padding="0,2">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="Переименовать"
                                        Clicked="OnRenameGroupClicked" />
                                <Button Grid.Column="2"
                                        Text="{x:Static res:AppResources.Delete}"
                                        BackgroundColor="Transparent"
                                        Clicked="OnDeleteGroupClicked" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Команды в стадию"
                       FontAttributes="Bold"
                       FontSize="14"
                       Margin="0,8,0,0" />
                <HorizontalStackLayout Spacing="12">
                    <Button Text="Добавить все"
                            Clicked="OnAddAllTeamsClicked" />
                    <Button Text="Добавить выбранные"
                            Clicked="OnAddSelectedTeamsClicked" />
                </HorizontalStackLayout>

                <CollectionView ItemsSource="{Binding AvailableTeams}"
                                SelectionMode="None"
                                HeightRequest="220">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,6" Padding="12" HasShadow="True" CornerRadius="8">
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding IsSelectedForAdd}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor"
                                                Value="{StaticResource Gray200Brush}" />
                                    </DataTrigger>
                                </Frame.Triggers>

                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAvailableTeamTapped" />
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Image Grid.Column="0"
                                           WidthRequest="32" HeightRequest="32"
                                           Source="{Binding IconPath, Converter={StaticResource PathToImageSource}}"
                                           Aspect="AspectFill" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Name}"
                                           FontSize="12"
                                           LineBreakMode="TailTruncation"
                                           VerticalTextAlignment="Center" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="{Binding MoveSelectedCount, StringFormat='Выбрано для перемещения: {0}'}"
                       FontSize="12"
                       TextColor="Gray"
                       Margin="0,4,0,0" />

                <Label Text="Группы стадии"
                       FontAttributes="Bold"
                       FontSize="14"
                       Margin="0,8,0,0" />

                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Default">
                    <HorizontalStackLayout Spacing="12"
                                            BindableLayout.ItemsSource="{Binding StageGroupColumns}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout WidthRequest="200" Spacing="6">
                                    <Label Text="{Binding Title}"
                                           FontAttributes="Bold"
                                           FontSize="14">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.MoveSelectedTeamsToGroupCommand, Source={x:Reference ThisPage}}"
                                                CommandParameter="{Binding GroupId}" />
                                        </Label.GestureRecognizers>
                                    </Label>

                                    <Button Text="Переместить"
                                            FontSize="12"
                                            Padding="0"
                                            Command="{Binding BindingContext.MoveSelectedTeamsToGroupCommand, Source={x:Reference ThisPage}}"
                                            CommandParameter="{Binding GroupId}" />

                                    <CollectionView ItemsSource="{Binding Teams}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Frame Padding="8"
                                                       HasShadow="True"
                                                       CornerRadius="8">
                                                    <Frame.Triggers>
                                                        <DataTrigger TargetType="Frame"
                                                                     Binding="{Binding IsSelectedForMove}"
                                                                     Value="True">
                                                            <Setter Property="BackgroundColor"
                                                                    Value="{StaticResource Gray200Brush}" />
                                                        </DataTrigger>
                                                    </Frame.Triggers>
                                                    <Frame.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnStageTeamTapped" />
                                                    </Frame.GestureRecognizers>

                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" >
                                                        <Image WidthRequest="24"
                                                               HeightRequest="24"
                                                               Source="{Binding IconPath, Converter={StaticResource PathToImageSource}}"
                                                               Aspect="AspectFill" />
                                                        <Label Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               FontSize="12"
                                                               LineBreakMode="TailTruncation"
                                                               VerticalTextAlignment="Center" />
                                                    </Grid>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- Турнирная таблица стадии -->
            <Label Text="{x:Static res:AppResources.StandingsTable}"
                   FontAttributes="Bold"
                   FontSize="18"
                   Margin="0,12,0,0" />
            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Default">
                <VerticalStackLayout Spacing="4" MinimumWidthRequest="720">
                    <Grid ColumnDefinitions="28,120,32,32,28,28,28,28,28,28,32,32,36,72,*"
                          Padding="0,4" ColumnSpacing="4">
                        <Label Grid.Column="0" Text="{x:Static res:AppResources.StandingsColPlace}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="{x:Static res:AppResources.StandingsColTeam}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="{x:Static res:AppResources.StandingsColPoints}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />
                        <Label Grid.Column="3" Text="{x:Static res:AppResources.StandingsColGames}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="4" Text="{x:Static res:AppResources.StandingsColW}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="5" Text="{x:Static res:AppResources.StandingsColWot}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="6" Text="{x:Static res:AppResources.StandingsColWso}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="7" Text="{x:Static res:AppResources.StandingsColLso}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="8" Text="{x:Static res:AppResources.StandingsColLot}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="9" Text="{x:Static res:AppResources.StandingsColL}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="10" Text="{x:Static res:AppResources.StandingsColGoalsFor}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="11" Text="{x:Static res:AppResources.StandingsColGoalsAgainst}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="12" Text="{x:Static res:AppResources.StandingsColGoalDiff}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="13" Text="{x:Static res:AppResources.StandingsColLast5}" FontSize="11" FontAttributes="Bold" />
                        <Label Grid.Column="14" Text="{x:Static res:AppResources.StandingsColPct}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    </Grid>
                    <CollectionView ItemsSource="{Binding StandingsByGroupForStage}"
                                    IsGrouped="True"
                                    VerticalOptions="Start">
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate>
                                <Label Text="{Binding GroupName}"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       Margin="0,12,0,4"
                                       IsVisible="{Binding GroupName, Converter={StaticResource GroupNameToVisibility}}" />
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="28,120,32,32,28,28,28,28,28,28,32,32,36,72,*"
                                      Padding="0,4" ColumnSpacing="4">
                                    <Label Grid.Column="0" Text="{Binding Place}" FontSize="12" />
                                    <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                        <Image WidthRequest="24" HeightRequest="24"
                                               Source="{Binding TeamIconPath, Converter={StaticResource PathToImageSource}}"
                                               Aspect="AspectFill" />
                                        <Label Text="{Binding TeamName}" FontSize="12" LineBreakMode="TailTruncation" VerticalTextAlignment="Center" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Column="2" Text="{Binding Points}" FontSize="12" HorizontalTextAlignment="End" />
                                    <Label Grid.Column="3" Text="{Binding Games}" FontSize="12" />
                                    <Label Grid.Column="4" Text="{Binding WinsReg}" FontSize="12" />
                                    <Label Grid.Column="5" Text="{Binding WinsOt}" FontSize="12" />
                                    <Label Grid.Column="6" Text="{Binding WinsSo}" FontSize="12" />
                                    <Label Grid.Column="7" Text="{Binding LossesSo}" FontSize="12" />
                                    <Label Grid.Column="8" Text="{Binding LossesOt}" FontSize="12" />
                                    <Label Grid.Column="9" Text="{Binding LossesReg}" FontSize="12" />
                                    <Label Grid.Column="10" Text="{Binding GoalsFor}" FontSize="12" />
                                    <Label Grid.Column="11" Text="{Binding GoalsAgainst}" FontSize="12" />
                                    <Label Grid.Column="12" Text="{Binding GoalDiff}" FontSize="12" />
                                    <HorizontalStackLayout Grid.Column="13" Spacing="2" VerticalOptions="Center"
                                                          BindableLayout.ItemsSource="{Binding Last5Results}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                                         BackgroundColor="{Binding Converter={StaticResource LastResultToColor}}" />
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </HorizontalStackLayout>
                                    <Label Grid.Column="14" Text="{Binding PointsPct}" FontSize="12" HorizontalTextAlignment="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Матчи стадии -->
            <Label Text="{x:Static res:AppResources.Matches}"
                   FontAttributes="Bold"
                   FontSize="18"
                   Margin="0,12,0,0" />
            <CollectionView ItemsSource="{Binding StageMatches}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid RowDefinitions="Auto,Auto,Auto" Padding="0,6">
                            <Label FontSize="12"
                                   Text="{Binding DateTime, StringFormat='{}{0:dd.MM HH:mm}'}" />
                            <Label Grid.Row="1" FontSize="14">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} – {1}  {2}">
                                        <Binding Path="HomeTeamName" />
                                        <Binding Path="AwayTeamName" />
                                        <Binding Path="DisplayScore" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                            <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto">
                                <Button Grid.Column="0"
                                        Text="{x:Static res:AppResources.StartMatch}"
                                        IsVisible="{Binding Status, Converter={StaticResource MatchStatusToStartVisible}}"
                                        Clicked="OnStartMatchClicked" />
                                <Button Grid.Column="1"
                                        Text="{x:Static res:AppResources.FinishMatch}"
                                        IsVisible="{Binding IsLive}"
                                        Clicked="OnFinishMatchClicked" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

