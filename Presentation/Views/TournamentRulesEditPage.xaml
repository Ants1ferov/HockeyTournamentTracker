<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.TournamentRulesEditPage"
             x:Name="ThisPage"
             Title="{x:Static res:AppResources.RulesScoringTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{x:Static res:AppResources.PointsWinReg}" />
            <Entry Text="{Binding PointsRegWin}" Keyboard="Numeric" />
            <Label Text="{x:Static res:AppResources.PointsWinOt}" />
            <Entry Text="{Binding PointsOtWin}" Keyboard="Numeric" />
            <Label Text="{x:Static res:AppResources.PointsWinSo}" />
            <Entry Text="{Binding PointsSoWin}" Keyboard="Numeric" />
            <Label Text="{x:Static res:AppResources.PointsLossReg}" />
            <Entry Text="{Binding PointsRegLoss}" Keyboard="Numeric" />
            <Label Text="{x:Static res:AppResources.PointsLossOt}" />
            <Entry Text="{Binding PointsOtLoss}" Keyboard="Numeric" />
            <Label Text="{x:Static res:AppResources.PointsLossSo}" />
            <Entry Text="{Binding PointsSoLoss}" Keyboard="Numeric" />

            <Label Text="{x:Static res:AppResources.SortOrderTitle}"
                   FontAttributes="Bold"
                   FontSize="14"
                   Margin="0,12,0,0" />
            <CollectionView ItemsSource="{Binding SortOrderList}" Margin="0,4,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="0,4" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="{Binding Converter={StaticResource StandingSortCriterionToString}}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="{x:Static res:AppResources.SortOrderMoveUp}" WidthRequest="36"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.MoveSortUpCommand}"
                                    CommandParameter="{Binding .}" />
                            <Button Grid.Column="2" Text="{x:Static res:AppResources.SortOrderMoveDown}" WidthRequest="36"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.MoveSortDownCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="{x:Static res:AppResources.Save}"
                    Margin="0,16,0,0"
                    Clicked="OnSaveClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
