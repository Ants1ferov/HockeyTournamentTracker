<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             xmlns:controls="clr-namespace:HockeyTournamentTracker.Presentation.Views.Controls"
             x:Class="HockeyTournamentTracker.Presentation.Views.TournamentDetailsPage"
             x:Name="ThisPage"
             Title="{Binding PageTitle}">

    <Grid x:Name="MainGrid" RowDefinitions="*,56" VerticalOptions="Fill">
        <ScrollView x:Name="MainScroll" Grid.Row="0">
            <VerticalStackLayout x:Name="MainContent" Padding="16" Spacing="16" VerticalOptions="Start">
                <!-- Вкладка Главная: видима при SelectedTabIndex == 0 -->
                <VerticalStackLayout x:Name="HomeTabContent" IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IndexEqualsToBool}, ConverterParameter=0}" Spacing="16">
                    <!-- Hero-карточка турнира -->
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Brand}, Dark={StaticResource BrandDark}}"
                            Padding="16,14">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0"
                                       Text="{Binding PageTitle}"
                                       TextColor="{StaticResource OnBrand}"
                                       FontAttributes="Bold"
                                       FontSize="24"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation" />
                                <Border Grid.Column="1"
                                        Style="{StaticResource StatusBadgeStyle}"
                                        VerticalOptions="Center"
                                        BackgroundColor="{Binding HeaderStatus, Converter={StaticResource StatusToBadgeColor}}">
                                    <Label Text="{Binding HeaderStatus, Converter={StaticResource TournamentStatusToString}}"
                                           TextColor="{Binding HeaderStatus, Converter={StaticResource StatusToBadgeTextColor}}"
                                           FontSize="11"
                                           FontAttributes="Bold" />
                                </Border>
                            </Grid>
                            <Label Grid.Row="1"
                                   Text="{Binding HeaderMeta}"
                                   TextColor="{StaticResource OnBrand}"
                                   Opacity="0.85"
                                   FontSize="13" />
                        </Grid>
                    </Border>
                    <Label Text="{Binding TournamentDescription}"
                           FontSize="14"
                           TextColor="Gray" />
                    <Label Text="{x:Static res:AppResources.LastPlayedMatches}"
                           FontAttributes="Bold"
                           FontSize="18"
                           Margin="0,16,0,0" />
                    <CollectionView ItemsSource="{Binding LastPlayedMatches}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <controls:MatchCardView Margin="0,4" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label Text="{x:Static res:AppResources.UpcomingMatches}"
                           FontAttributes="Bold"
                           FontSize="18"
                           Margin="0,16,0,0" />
                    <CollectionView ItemsSource="{Binding UpcomingMatches}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Margin="0,4" Spacing="6">
                                    <controls:MatchCardView />
                                    <Button Text="Редактировать матч"
                                            Clicked="OnFinishMatchClicked" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Вкладка Стадии -->
                <VerticalStackLayout IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IndexEqualsToBool}, ConverterParameter=1}" Spacing="16">
                    <Button Text="{x:Static res:AppResources.AddStage}"
                            Clicked="OnAddStageClicked" />
                    <Label Text="{x:Static res:AppResources.TabStages}"
                           FontAttributes="Bold"
                           FontSize="18" />
                    <CollectionView ItemsSource="{Binding Stages}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="{x:Static res:AppResources.Delete}"
                                                       BackgroundColor="Red"
                                                       Invoked="OnDeleteStageInvoked" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Frame Margin="0,4"
                                           Padding="12"
                                           HasShadow="False"
                                           CornerRadius="8"
                                           Style="{StaticResource CardFrameStyle}">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnStageTapped" />
                                        </Frame.GestureRecognizers>
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                                            <Label Text="{Binding StageType, Converter={StaticResource StageTypeToString}}"
                                                   FontSize="12"
                                                   TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                                        </VerticalStackLayout>
                                    </Frame>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label Text="{x:Static res:AppResources.StandingsTable}"
                           FontAttributes="Bold"
                           FontSize="18"
                           IsVisible="{Binding IsSelectedStageSwiss}"
                           Margin="0,12,0,0" />
                    <!-- Переключатель Компактно / Подробно -->
                    <HorizontalStackLayout Spacing="8"
                                           IsVisible="{Binding IsSelectedStageSwiss}">
                        <Label Text="Компактно" FontSize="13" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding ShowFullStandings}" />
                        <Label Text="Подробно" FontSize="13" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <!-- Компактная таблица (как в мокапе): зебра + полоса зоны -->
                    <CollectionView ItemsSource="{Binding StandingsByGroupForStage}"
                                    IsGrouped="True"
                                    VerticalOptions="Start"
                                    IsVisible="{Binding ShowCompactStandings}">
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Margin="0,12,0,4" Spacing="4">
                                    <Label Text="{Binding GroupName}"
                                           FontAttributes="Bold"
                                           FontSize="14"
                                           IsVisible="{Binding GroupName, Converter={StaticResource GroupNameToVisibility}}" />
                                    <Grid ColumnDefinitions="4,*">
                                        <Grid Grid.Column="1"
                                              ColumnDefinitions="34,*,44,44,64"
                                              Padding="6,6"
                                              ColumnSpacing="6"
                                              BackgroundColor="{AppThemeBinding Light={StaticResource TableHeaderAltLight}, Dark={StaticResource TableHeaderAltDark}}">
                                            <Label Grid.Column="0" Text="{x:Static res:AppResources.StandingsColPlace}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                            <Label Grid.Column="1" Text="{x:Static res:AppResources.StandingsColTeam}" FontSize="12" FontAttributes="Bold" />
                                            <Label Grid.Column="2" Text="{x:Static res:AppResources.StandingsColGames}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                            <Label Grid.Column="3" Text="{x:Static res:AppResources.StandingsColPoints}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                            <Label Grid.Column="4" Text="В-П" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                        </Grid>
                                    </Grid>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="4,*" ColumnSpacing="0">
                                    <BoxView Grid.Column="0"
                                             BackgroundColor="{Binding ZoneColorHex, Converter={StaticResource HexColorToColor}}"
                                             VerticalOptions="Fill" />
                                    <Grid Grid.Column="1"
                                          ColumnDefinitions="34,*,44,44,64"
                                          Padding="6,8"
                                          ColumnSpacing="6"
                                          BackgroundColor="{Binding IsAltRow, Converter={StaticResource BoolToZebraColor}}">
                                        <Label Grid.Column="0" Text="{Binding Place}" FontSize="13" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                            <Image WidthRequest="20" HeightRequest="20"
                                                   Source="{Binding TeamIconPath, Converter={StaticResource PathToImageSource}}"
                                                   Aspect="AspectFill" />
                                            <Label Text="{Binding TeamName}" FontSize="13" LineBreakMode="TailTruncation" VerticalTextAlignment="Center" />
                                        </HorizontalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding Games}" FontSize="13" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="3" Text="{Binding Points}" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="4" Text="{Binding RecordSummary}" FontSize="13" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <!-- Полная таблица: все колонки, горизонтальный скролл -->
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Default"
                                IsVisible="{Binding ShowFullStandingsTable}">
                        <CollectionView ItemsSource="{Binding StandingsByGroupForStage}"
                                        IsGrouped="True"
                                        VerticalOptions="Start"
                                        MinimumWidthRequest="820">
                            <CollectionView.GroupHeaderTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Margin="0,12,0,4" Spacing="4">
                                        <Label Text="{Binding GroupName}"
                                               FontAttributes="Bold"
                                               FontSize="14"
                                               IsVisible="{Binding GroupName, Converter={StaticResource GroupNameToVisibility}}" />
                                        <Grid ColumnDefinitions="36,170,50,50,40,40,40,40,40,40,44,44,46,88,*"
                                              Padding="4,6"
                                              ColumnSpacing="6"
                                              BackgroundColor="{AppThemeBinding Light={StaticResource TableCellAltLight}, Dark={StaticResource TableCellAltDark}}">
                                            <Label Grid.Column="0" Text="{x:Static res:AppResources.StandingsColPlace}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="1" Text="{x:Static res:AppResources.StandingsColTeam}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="2" Text="{x:Static res:AppResources.StandingsColPoints}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableHeaderAltLight}, Dark={StaticResource TableHeaderAltDark}}" />
                                            <Label Grid.Column="3" Text="{x:Static res:AppResources.StandingsColGames}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="4" Text="{x:Static res:AppResources.StandingsColW}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableHeaderAltLight}, Dark={StaticResource TableHeaderAltDark}}" />
                                            <Label Grid.Column="5" Text="{x:Static res:AppResources.StandingsColWot}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="6" Text="{x:Static res:AppResources.StandingsColWso}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableHeaderAltLight}, Dark={StaticResource TableHeaderAltDark}}" />
                                            <Label Grid.Column="7" Text="{x:Static res:AppResources.StandingsColLso}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="8" Text="{x:Static res:AppResources.StandingsColLot}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableHeaderAltLight}, Dark={StaticResource TableHeaderAltDark}}" />
                                            <Label Grid.Column="9" Text="{x:Static res:AppResources.StandingsColL}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="10" Text="{x:Static res:AppResources.StandingsColGoalsFor}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableHeaderAltLight}, Dark={StaticResource TableHeaderAltDark}}" />
                                            <Label Grid.Column="11" Text="{x:Static res:AppResources.StandingsColGoalsAgainst}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="12" Text="{x:Static res:AppResources.StandingsColGoalDiff}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableHeaderAltLight}, Dark={StaticResource TableHeaderAltDark}}" />
                                            <Label Grid.Column="13" Text="{x:Static res:AppResources.StandingsColLast5}" FontSize="11" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="14" Text="{x:Static res:AppResources.StandingsColPct}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableHeaderAltLight}, Dark={StaticResource TableHeaderAltDark}}" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.GroupHeaderTemplate>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="4,*" ColumnSpacing="0" Padding="0,3">
                                        <BoxView Grid.Column="0"
                                                 BackgroundColor="{Binding ZoneColorHex, Converter={StaticResource HexColorToColor}}"
                                                 VerticalOptions="Fill" />
                                        <Grid Grid.Column="1"
                                              ColumnDefinitions="36,170,50,50,40,40,40,40,40,40,44,44,46,88,*"
                                              Padding="0,3"
                                              ColumnSpacing="6">
                                            <Label Grid.Column="0" Text="{Binding Place}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center" HorizontalOptions="Fill" Padding="4,0">
                                                <Image WidthRequest="24" HeightRequest="24"
                                                       Source="{Binding TeamIconPath, Converter={StaticResource PathToImageSource}}"
                                                       Aspect="AspectFill" />
                                                <Label Text="{Binding TeamName}" FontSize="12" LineBreakMode="TailTruncation" VerticalTextAlignment="Center" HorizontalTextAlignment="Center" HorizontalOptions="FillAndExpand" />
                                            </HorizontalStackLayout>
                                            <Label Grid.Column="2" Text="{Binding Points}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableCellAltLight}, Dark={StaticResource TableCellAltDark}}" />
                                            <Label Grid.Column="3" Text="{Binding Games}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="4" Text="{Binding WinsReg}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableCellAltLight}, Dark={StaticResource TableCellAltDark}}" />
                                            <Label Grid.Column="5" Text="{Binding WinsOt}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="6" Text="{Binding WinsSo}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableCellAltLight}, Dark={StaticResource TableCellAltDark}}" />
                                            <Label Grid.Column="7" Text="{Binding LossesSo}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="8" Text="{Binding LossesOt}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableCellAltLight}, Dark={StaticResource TableCellAltDark}}" />
                                            <Label Grid.Column="9" Text="{Binding LossesReg}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="10" Text="{Binding GoalsFor}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableCellAltLight}, Dark={StaticResource TableCellAltDark}}" />
                                            <Label Grid.Column="11" Text="{Binding GoalsAgainst}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="12" Text="{Binding GoalDiff}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableCellAltLight}, Dark={StaticResource TableCellAltDark}}" />
                                            <HorizontalStackLayout Grid.Column="13"
                                                                  Spacing="2"
                                                                  VerticalOptions="Center"
                                                                  HorizontalOptions="Center"
                                                                  BindableLayout.ItemsSource="{Binding Last5Results}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate>
                                                        <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                                                 BackgroundColor="{Binding Converter={StaticResource LastResultToColor}}" />
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </HorizontalStackLayout>
                                            <Label Grid.Column="14" Text="{Binding PointsPct}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="{AppThemeBinding Light={StaticResource TableCellAltLight}, Dark={StaticResource TableCellAltDark}}" />
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </ScrollView>
                    <Label Text="{x:Static res:AppResources.Matches}"
                           FontAttributes="Bold"
                           FontSize="16"
                           IsVisible="{Binding SelectedStage, Converter={StaticResource NotNullToBool}}"
                           Margin="0,12,0,0" />
                    <Button Text="{x:Static res:AppResources.AddMatch}"
                            Clicked="OnAddMatchInStageClicked"
                            IsVisible="{Binding SelectedStage, Converter={StaticResource NotNullToBool}}" />
                    <CollectionView ItemsSource="{Binding StageMatches}"
                                    IsVisible="{Binding SelectedStage, Converter={StaticResource NotNullToBool}}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Margin="0,4" Spacing="6">
                                    <controls:MatchCardView />
                                    <Button Text="Редактировать матч"
                                            Clicked="OnFinishMatchClicked" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Вкладка Участники -->
                <VerticalStackLayout IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IndexEqualsToBool}, ConverterParameter=2}" Spacing="16">
                    <Button Text="{x:Static res:AppResources.AddTeam}"
                            Clicked="OnAddParticipantClicked" />
                    <CollectionView ItemsSource="{Binding ParticipantTeams}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="{x:Static res:AppResources.Delete}"
                                                       BackgroundColor="Red"
                                                       Invoked="OnDeleteParticipantInvoked" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Frame Margin="12,6"
                                           Padding="12"
                                           HasShadow="False"
                                           CornerRadius="8"
                                           Style="{StaticResource CardFrameStyle}">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnParticipantTapped" />
                                        </Frame.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                            <Image Grid.Column="0"
                                                   WidthRequest="40" HeightRequest="40"
                                                   Source="{Binding IconPath, Converter={StaticResource PathToImageSource}}"
                                                   Aspect="AspectFill" />
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                                                <Label Text="{Binding ShortName}"
                                                       FontSize="12"
                                                       TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Frame>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Вкладка Статистика -->
                <VerticalStackLayout IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IndexEqualsToBool}, ConverterParameter=3}" Spacing="12">
                    <Label Text="{x:Static res:AppResources.TabStatistics}"
                           FontAttributes="Bold"
                           FontSize="18" />
                    <Label Text="{x:Static res:AppResources.StatisticsTabHint}"
                           FontSize="13"
                           TextColor="Gray" />
                    <Button Text="{x:Static res:AppResources.OpenStatistics}"
                            Clicked="OnOpenStatisticsClicked" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Плавающая кнопка меню действий турнира (статус / правила) -->
        <Border Grid.Row="0"
                WidthRequest="56" HeightRequest="56"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 28"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,16,16"
                BackgroundColor="{AppThemeBinding Light={StaticResource Brand}, Dark={StaticResource BrandDark}}"
                IsVisible="{Binding IsHomeTabSelected}">
            <Border.Shadow>
                <Shadow Brush="{StaticResource BlackBrush}" Radius="8" Opacity="0.25" Offset="0,2" />
            </Border.Shadow>
            <Label Text="⋮"
                   TextColor="{StaticResource OnBrand}"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTournamentMenuClicked" />
            </Border.GestureRecognizers>
        </Border>

        <!-- Нижняя панель вкладок: полностью своя разметка без стилей Button,
             чтобы текст не обрезался и был виден в любой теме -->
        <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource Gray200Brush}, Dark={StaticResource Gray600Brush}}" Padding="0,4">
            <Grid ColumnDefinitions="*,*,*,*" VerticalOptions="Center" HeightRequest="64">
                <!-- Главная -->
                <VerticalStackLayout Grid.Column="0"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center"
                                      Spacing="2">
                    <Image WidthRequest="28" HeightRequest="28"
                           Source="{Binding HomeTabIcon, Converter={StaticResource MauiImageAliasToImageSource}}"
                           VerticalOptions="Center" />
                    <Label Text="{x:Static res:AppResources.TabHome}"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabHomeClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <!-- Стадии -->
                <VerticalStackLayout Grid.Column="1"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center"
                                      Spacing="2">
                    <Image WidthRequest="28" HeightRequest="28"
                           Source="{Binding StagesTabIcon, Converter={StaticResource MauiImageAliasToImageSource}}"
                           VerticalOptions="Center" />
                    <Label Text="{x:Static res:AppResources.TabStages}"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabStagesClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <!-- Участники -->
                <VerticalStackLayout Grid.Column="2"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center"
                                      Spacing="2">
                    <Image WidthRequest="28" HeightRequest="28"
                           Source="{Binding ParticipantsTabIcon, Converter={StaticResource MauiImageAliasToImageSource}}"
                           VerticalOptions="Center" />
                    <Label Text="{x:Static res:AppResources.TabParticipants}"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabParticipantsClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <!-- Статистика -->
                <VerticalStackLayout Grid.Column="3"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center"
                                      Spacing="2">
                    <Label Text="▣"
                           FontSize="20"
                           HorizontalTextAlignment="Center"
                           TextColor="{Binding StatisticsTabLabelColorHex, Converter={StaticResource HexColorToColor}}" />
                    <Label Text="{x:Static res:AppResources.TabStatistics}"
                           FontSize="11"
                           HorizontalTextAlignment="Center"
                           TextColor="{Binding StatisticsTabLabelColorHex, Converter={StaticResource HexColorToColor}}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabStatisticsClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
