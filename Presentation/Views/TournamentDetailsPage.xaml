<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.TournamentDetailsPage"
             Title="{Binding Tournament.Name}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <Label Text="{Binding Tournament.Name}"
                   FontAttributes="Bold"
                   FontSize="22" />

            <Button Text="{x:Static res:AppResources.Teams}"
                    Clicked="OnTeamsClicked" />
            <Button Text="{x:Static res:AppResources.Groups}"
                    Clicked="OnGroupsClicked" />

            <Label Text="{x:Static res:AppResources.Status}" FontAttributes="Bold" FontSize="14" />
            <Picker Title="{x:Static res:AppResources.Status}"
                    SelectedIndex="{Binding StatusIndex}">
                <Picker.Items>
                    <x:String>Запланирован</x:String>
                    <x:String>В процессе</x:String>
                    <x:String>Завершён</x:String>
                    <x:String>В архиве</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="{x:Static res:AppResources.RulesScoringTitle}"
                   FontAttributes="Bold"
                   FontSize="14" />
            <VerticalStackLayout Spacing="4">
                <Label FontSize="12">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0}: {1}">
                            <Binding Source="{x:Static res:AppResources.StandingsColW}" />
                            <Binding Path="PointsRegWinText" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <Label FontSize="12">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0}: {1}">
                            <Binding Source="{x:Static res:AppResources.StandingsColWot}" />
                            <Binding Path="PointsOtWinText" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <Label FontSize="12">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0}: {1}">
                            <Binding Source="{x:Static res:AppResources.StandingsColWso}" />
                            <Binding Path="PointsSoWinText" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <Label FontSize="12">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0}: {1}">
                            <Binding Source="{x:Static res:AppResources.StandingsColL}" />
                            <Binding Path="PointsRegLossText" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <Label FontSize="12">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0}: {1}">
                            <Binding Source="{x:Static res:AppResources.StandingsColLot}" />
                            <Binding Path="PointsOtLossText" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <Label FontSize="12">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0}: {1}">
                            <Binding Source="{x:Static res:AppResources.StandingsColLso}" />
                            <Binding Path="PointsSoLossText" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
            </VerticalStackLayout>
            <Button Text="{x:Static res:AppResources.EditRules}"
                    Clicked="OnEditRulesClicked" />

            <Label Text="{Binding Tournament.Description}"
                   FontSize="14"
                   TextColor="Gray" />

            <Label Text="{x:Static res:AppResources.StandingsTable}"
                   FontAttributes="Bold"
                   FontSize="18" />

            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Default">
                <VerticalStackLayout Spacing="4" MinimumWidthRequest="750">
                    <Grid ColumnDefinitions="28,36,100,28,28,28,28,28,28,28,32,32,36,58,40,36" Padding="0,4" ColumnSpacing="2">
                        <Label Grid.Column="0" Text="{x:Static res:AppResources.StandingsColPlace}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="{x:Static res:AppResources.StandingsColGroup}" FontSize="11" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="{x:Static res:AppResources.StandingsColTeam}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="{x:Static res:AppResources.StandingsColGames}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="3" Text="{x:Static res:AppResources.StandingsColW}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="4" Text="{x:Static res:AppResources.StandingsColWot}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="5" Text="{x:Static res:AppResources.StandingsColWso}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="6" Text="{x:Static res:AppResources.StandingsColL}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="7" Text="{x:Static res:AppResources.StandingsColLot}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="8" Text="{x:Static res:AppResources.StandingsColLso}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="9" Text="{x:Static res:AppResources.StandingsColGoalsFor}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="10" Text="{x:Static res:AppResources.StandingsColGoalsAgainst}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="11" Text="{x:Static res:AppResources.StandingsColGoalDiff}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="12" Text="{x:Static res:AppResources.StandingsColGoalDiff}" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="13" Text="{x:Static res:AppResources.StandingsColLast5}" FontSize="11" FontAttributes="Bold" />
                        <Label Grid.Column="14" Text="{x:Static res:AppResources.StandingsColPct}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />
                        <Label Grid.Column="15" Text="{x:Static res:AppResources.StandingsColPoints}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    </Grid>
                    <CollectionView ItemsSource="{Binding Standings}"
                                   VerticalOptions="Start">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="28,36,100,28,28,28,28,28,28,28,32,32,36,58,40,36"
                                      Padding="0,4" ColumnSpacing="2">
                                    <Label Grid.Column="0" Text="{Binding Place}" FontSize="12" />
                                    <Label Grid.Column="1" Text="{Binding GroupName}" FontSize="11" LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="2" Text="{Binding TeamName}" FontSize="12" LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="3" Text="{Binding Games}" FontSize="12" />
                                    <Label Grid.Column="4" Text="{Binding WinsReg}" FontSize="12" />
                                    <Label Grid.Column="5" Text="{Binding WinsOt}" FontSize="12" />
                                    <Label Grid.Column="6" Text="{Binding WinsSo}" FontSize="12" />
                                    <Label Grid.Column="7" Text="{Binding LossesReg}" FontSize="12" />
                                    <Label Grid.Column="8" Text="{Binding LossesOt}" FontSize="12" />
                                    <Label Grid.Column="9" Text="{Binding LossesSo}" FontSize="12" />
                                    <Label Grid.Column="10" Text="{Binding GoalsFor}" FontSize="12" />
                                    <Label Grid.Column="11" Text="{Binding GoalsAgainst}" FontSize="12" />
                                    <Label Grid.Column="12" Text="{Binding GoalDiff}" FontSize="12" />
                                    <HorizontalStackLayout Grid.Column="13" Spacing="2" VerticalOptions="Center"
                                                          BindableLayout.ItemsSource="{Binding Last5Results}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                                         BackgroundColor="{Binding Converter={StaticResource LastResultToColor}}" />
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </HorizontalStackLayout>
                                    <Label Grid.Column="14" Text="{Binding PointsPct}" FontSize="12" HorizontalTextAlignment="End" />
                                    <Label Grid.Column="15" Text="{Binding Points}" FontSize="12" HorizontalTextAlignment="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

            <Label Text="{x:Static res:AppResources.LiveMatches}"
                   FontAttributes="Bold"
                   FontSize="18"
                   Margin="0,16,0,0" />

            <CollectionView ItemsSource="{Binding LiveMatches}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid RowDefinitions="Auto,Auto,Auto" Padding="0,6">
                            <HorizontalStackLayout Grid.Row="0" Spacing="8">
                                <Label Text="{x:Static res:AppResources.Live}"
                                       TextColor="Red"
                                       FontAttributes="Bold"
                                       FontSize="12" />
                                <Label FontSize="12"
                                       Text="{Binding DateTime, StringFormat='{}{0:dd.MM HH:mm}'}" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1" FontSize="14">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} – {1}  {2}">
                                        <Binding Path="HomeTeamName" />
                                        <Binding Path="AwayTeamName" />
                                        <Binding Path="DisplayScore" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                            <Button Grid.Row="2"
                                    Text="{x:Static res:AppResources.FinishMatch}"
                                    Clicked="OnFinishMatchClicked" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{x:Static res:AppResources.Matches}"
                   FontAttributes="Bold"
                   FontSize="18"
                   Margin="0,16,0,0" />

            <Button Text="{x:Static res:AppResources.AddMatch}"
                    Clicked="OnAddMatchClicked" />

            <CollectionView ItemsSource="{Binding Matches}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid RowDefinitions="Auto,Auto,Auto" Padding="0,6">
                            <HorizontalStackLayout Grid.Row="0" Spacing="8">
                                <Label FontSize="12"
                                       Text="{Binding DateTime, StringFormat='{}{0:dd.MM HH:mm}'}" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1" FontSize="14">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} – {1}  {2}">
                                        <Binding Path="HomeTeamName" />
                                        <Binding Path="AwayTeamName" />
                                        <Binding Path="DisplayScore" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                            <Button Grid.Row="2"
                                    Text="{x:Static res:AppResources.StartMatch}"
                                    IsVisible="{Binding Status, Converter={StaticResource MatchStatusToStartVisible}}"
                                    Clicked="OnStartMatchClicked" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

