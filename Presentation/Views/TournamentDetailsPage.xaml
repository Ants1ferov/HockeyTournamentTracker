<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.TournamentDetailsPage"
             x:Name="ThisPage"
             Title="{Binding PageTitle}">

    <Grid x:Name="MainGrid" RowDefinitions="*,56" VerticalOptions="Fill">
        <ScrollView x:Name="MainScroll" Grid.Row="0">
            <VerticalStackLayout x:Name="MainContent" Padding="16" Spacing="16" VerticalOptions="Start">
                <!-- Вкладка Главная: видима при SelectedTabIndex == 0 -->
                <VerticalStackLayout x:Name="HomeTabContent" IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IndexEqualsToBool}, ConverterParameter=0}" Spacing="16">
                    <Label Text="{Binding PageTitle}"
                           FontAttributes="Bold"
                           FontSize="22" />
                    <Label Text="{x:Static res:AppResources.Status}" FontAttributes="Bold" FontSize="14" />
                    <Picker Title="{x:Static res:AppResources.Status}"
                            SelectedIndex="{Binding StatusIndex}">
                        <Picker.Items>
                            <x:String>Запланирован</x:String>
                            <x:String>В процессе</x:String>
                            <x:String>Завершён</x:String>
                            <x:String>В архиве</x:String>
                        </Picker.Items>
                    </Picker>
                    <Label Text="{x:Static res:AppResources.RulesTournamentTitle}"
                           FontAttributes="Bold"
                           FontSize="14" />
                    <Label Text="{x:Static res:AppResources.RulesScoringTitle}"
                           FontAttributes="Bold"
                           FontSize="12" />
                    <VerticalStackLayout Spacing="4">
                        <Label FontSize="12">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}: {1}">
                                    <Binding Source="{x:Static res:AppResources.StandingsColW}" />
                                    <Binding Path="PointsRegWinText" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Label FontSize="12">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}: {1}">
                                    <Binding Source="{x:Static res:AppResources.StandingsColWot}" />
                                    <Binding Path="PointsOtWinText" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Label FontSize="12">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}: {1}">
                                    <Binding Source="{x:Static res:AppResources.StandingsColWso}" />
                                    <Binding Path="PointsSoWinText" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Label FontSize="12">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}: {1}">
                                    <Binding Source="{x:Static res:AppResources.StandingsColL}" />
                                    <Binding Path="PointsRegLossText" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Label FontSize="12">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}: {1}">
                                    <Binding Source="{x:Static res:AppResources.StandingsColLot}" />
                                    <Binding Path="PointsOtLossText" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Label FontSize="12">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}: {1}">
                                    <Binding Source="{x:Static res:AppResources.StandingsColLso}" />
                                    <Binding Path="PointsSoLossText" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </VerticalStackLayout>
                    <Label Text="{x:Static res:AppResources.SortOrderTitle}"
                           FontAttributes="Bold"
                           FontSize="12" />
                    <CollectionView ItemsSource="{Binding SortOrderDisplay}"
                                    Margin="0,4,0,0">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label FontSize="12"
                                       Text="{Binding Converter={StaticResource StandingSortCriterionToString}}"
                                       Margin="0,2,0,0" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Button Text="{x:Static res:AppResources.EditRules}"
                            Clicked="OnEditRulesClicked" />
                    <Label Text="{Binding TournamentDescription}"
                           FontSize="14"
                           TextColor="Gray" />
                    <Label Text="{x:Static res:AppResources.LastPlayedMatches}"
                           FontAttributes="Bold"
                           FontSize="18"
                           Margin="0,16,0,0" />
                    <CollectionView ItemsSource="{Binding LastPlayedMatches}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid RowDefinitions="Auto,Auto" Padding="0,6">
                                    <Label FontSize="12"
                                           Text="{Binding DateTime, StringFormat='{}{0:dd.MM HH:mm}'}" />
                                    <Label Grid.Row="1" FontSize="14">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} – {1}  {2}">
                                                <Binding Path="HomeTeamName" />
                                                <Binding Path="AwayTeamName" />
                                                <Binding Path="DisplayScore" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label Text="{x:Static res:AppResources.UpcomingMatches}"
                           FontAttributes="Bold"
                           FontSize="18"
                           Margin="0,16,0,0" />
                    <CollectionView ItemsSource="{Binding UpcomingMatches}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid RowDefinitions="Auto,Auto,Auto" Padding="0,6">
                                    <HorizontalStackLayout Grid.Row="0" Spacing="8">
                                        <Label Text="{x:Static res:AppResources.Live}"
                                               TextColor="Red"
                                               FontAttributes="Bold"
                                               FontSize="12"
                                               IsVisible="{Binding IsLive}" />
                                        <Label FontSize="12"
                                               Text="{Binding DateTime, StringFormat='{}{0:dd.MM HH:mm}'}" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" FontSize="14">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} – {1}  {2}">
                                                <Binding Path="HomeTeamName" />
                                                <Binding Path="AwayTeamName" />
                                                <Binding Path="DisplayScore" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Button Grid.Row="2"
                                            Text="Редактировать матч"
                                            Clicked="OnFinishMatchClicked" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Вкладка Стадии -->
                <VerticalStackLayout IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IndexEqualsToBool}, ConverterParameter=1}" Spacing="16">
                    <Button Text="{x:Static res:AppResources.AddStage}"
                            Clicked="OnAddStageClicked" />
                    <Label Text="{x:Static res:AppResources.TabStages}"
                           FontAttributes="Bold"
                           FontSize="18" />
                    <CollectionView ItemsSource="{Binding Stages}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="{x:Static res:AppResources.Delete}"
                                                       BackgroundColor="Red"
                                                       Invoked="OnDeleteStageInvoked" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Frame Margin="0,4" Padding="12" HasShadow="True" CornerRadius="8">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnStageTapped" />
                                        </Frame.GestureRecognizers>
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                                            <Label Text="{Binding StageType, Converter={StaticResource StageTypeToString}}"
                                                   FontSize="12"
                                                   TextColor="Gray" />
                                        </VerticalStackLayout>
                                    </Frame>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label Text="{x:Static res:AppResources.StandingsTable}"
                           FontAttributes="Bold"
                           FontSize="18"
                           IsVisible="{Binding SelectedStage, Converter={StaticResource NotNullToBool}}"
                           Margin="0,12,0,0" />
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Default"
                                IsVisible="{Binding SelectedStage, Converter={StaticResource NotNullToBool}}">
                        <CollectionView ItemsSource="{Binding StandingsByGroupForStage}"
                                        IsGrouped="True"
                                        VerticalOptions="Start"
                                        MinimumWidthRequest="900">
                            <CollectionView.GroupHeaderTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Margin="0,12,0,4" Spacing="4">
                                        <Label Text="{Binding GroupName}"
                                               FontAttributes="Bold"
                                               FontSize="14"
                                               IsVisible="{Binding GroupName, Converter={StaticResource GroupNameToVisibility}}" />
                                        <Grid ColumnDefinitions="6,80,36,170,50,50,40,40,40,40,40,40,44,44,46,88,*"
                                              Padding="0,6"
                                              ColumnSpacing="6"
                                              BackgroundColor="#F3F4F6">
                                            <BoxView Grid.Column="0"
                                                     WidthRequest="{Binding Source={x:Reference ThisPage}, Path=BindingContext.IsSelectedStageSwiss, Converter={StaticResource BoolToDouble}, ConverterParameter=6|0}"
                                                     Color="Transparent" />
                                            <Label Grid.Column="1"
                                                   Text="{x:Static res:AppResources.StandingZoneColumn}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   VerticalTextAlignment="Center"
                                                   WidthRequest="{Binding Source={x:Reference ThisPage}, Path=BindingContext.IsSelectedStageSwiss, Converter={StaticResource BoolToDouble}, ConverterParameter=80|0}"
                                                   IsVisible="{Binding Source={x:Reference ThisPage}, Path=BindingContext.IsSelectedStageSwiss}" />
                                            <Label Grid.Column="2" Text="{x:Static res:AppResources.StandingsColPlace}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="3" Text="{x:Static res:AppResources.StandingsColTeam}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="4" Text="{x:Static res:AppResources.StandingsColPoints}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#E5E7EB" />
                                            <Label Grid.Column="5" Text="{x:Static res:AppResources.StandingsColGames}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="6" Text="{x:Static res:AppResources.StandingsColW}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#E5E7EB" />
                                            <Label Grid.Column="7" Text="{x:Static res:AppResources.StandingsColWot}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="8" Text="{x:Static res:AppResources.StandingsColWso}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#E5E7EB" />
                                            <Label Grid.Column="9" Text="{x:Static res:AppResources.StandingsColLso}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="10" Text="{x:Static res:AppResources.StandingsColLot}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#E5E7EB" />
                                            <Label Grid.Column="11" Text="{x:Static res:AppResources.StandingsColL}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="12" Text="{x:Static res:AppResources.StandingsColGoalsFor}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#E5E7EB" />
                                            <Label Grid.Column="13" Text="{x:Static res:AppResources.StandingsColGoalsAgainst}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="14" Text="{x:Static res:AppResources.StandingsColGoalDiff}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#E5E7EB" />
                                            <Label Grid.Column="15" Text="{x:Static res:AppResources.StandingsColLast5}" FontSize="11" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="16" Text="{x:Static res:AppResources.StandingsColPct}" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#E5E7EB" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.GroupHeaderTemplate>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="6,80,36,170,50,50,40,40,40,40,40,40,44,44,46,88,*"
                                          Padding="0,6"
                                          ColumnSpacing="6">
                                        <BoxView Grid.Column="0"
                                                 WidthRequest="{Binding ZoneBarColumnWidth}"
                                                 CornerRadius="2"
                                                 VerticalOptions="Fill"
                                                 HorizontalOptions="Fill"
                                                 Color="{Binding ZoneBarColorHex, Converter={StaticResource HexColorToColor}}"
                                                 IsVisible="{Binding ShowZoneUi}" />
                                        <Picker Grid.Column="1"
                                                ItemsSource="{Binding Source={x:Reference ThisPage}, Path=BindingContext.StageZonePickerRows}"
                                                ItemDisplayBinding="{Binding Title}"
                                                SelectedIndex="{Binding ZonePickerIndex}"
                                                FontSize="11"
                                                WidthRequest="{Binding ShowZoneUi, Converter={StaticResource BoolToDouble}, ConverterParameter=86|0}"
                                                IsVisible="{Binding ShowZoneUi}"
                                                SelectedIndexChanged="OnStandingZonePickerChanged" />
                                        <Label Grid.Column="2" Text="{Binding Place}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        <HorizontalStackLayout Grid.Column="3" Spacing="6" VerticalOptions="Center" HorizontalOptions="Fill" Padding="4,0">
                                            <Image WidthRequest="24" HeightRequest="24"
                                                   Source="{Binding TeamIconPath, Converter={StaticResource PathToImageSource}}"
                                                   Aspect="AspectFill" />
                                            <Label Text="{Binding TeamName}" FontSize="12" LineBreakMode="TailTruncation" VerticalTextAlignment="Center" HorizontalTextAlignment="Center" HorizontalOptions="FillAndExpand" />
                                        </HorizontalStackLayout>
                                        <Label Grid.Column="4" Text="{Binding Points}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#F3F4F6" />
                                        <Label Grid.Column="5" Text="{Binding Games}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="6" Text="{Binding WinsReg}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#F3F4F6" />
                                        <Label Grid.Column="7" Text="{Binding WinsOt}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="8" Text="{Binding WinsSo}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#F3F4F6" />
                                        <Label Grid.Column="9" Text="{Binding LossesSo}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="10" Text="{Binding LossesOt}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#F3F4F6" />
                                        <Label Grid.Column="11" Text="{Binding LossesReg}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="12" Text="{Binding GoalsFor}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#F3F4F6" />
                                        <Label Grid.Column="13" Text="{Binding GoalsAgainst}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="14" Text="{Binding GoalDiff}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#F3F4F6" />
                                        <HorizontalStackLayout Grid.Column="15"
                                                              Spacing="2"
                                                              VerticalOptions="Center"
                                                              HorizontalOptions="Center"
                                                              BindableLayout.ItemsSource="{Binding Last5Results}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate>
                                                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                                             BackgroundColor="{Binding Converter={StaticResource LastResultToColor}}" />
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </HorizontalStackLayout>
                                        <Label Grid.Column="16" Text="{Binding PointsPct}" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" BackgroundColor="#F3F4F6" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </ScrollView>
                    <VerticalStackLayout Spacing="8"
                                         Margin="0,8,0,0"
                                         IsVisible="{Binding IsSelectedStageSwiss}">
                        <Label Text="{x:Static res:AppResources.LegendTitle}"
                               FontAttributes="Bold"
                               FontSize="14" />
                        <FlexLayout Wrap="Wrap"
                                    AlignItems="Start"
                                    BindableLayout.ItemsSource="{Binding StageZoneLegend}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <HorizontalStackLayout Spacing="8" Margin="0,0,16,8">
                                        <BoxView WidthRequest="16"
                                                 HeightRequest="16"
                                                 CornerRadius="8"
                                                 VerticalOptions="Center"
                                                 Color="{Binding ColorHex, Converter={StaticResource HexColorToColor}}" />
                                        <Label Text="{Binding Name}"
                                               FontSize="12"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </VerticalStackLayout>
                    <Label Text="{x:Static res:AppResources.Matches}"
                           FontAttributes="Bold"
                           FontSize="16"
                           IsVisible="{Binding SelectedStage, Converter={StaticResource NotNullToBool}}"
                           Margin="0,12,0,0" />
                    <Button Text="{x:Static res:AppResources.AddMatch}"
                            Clicked="OnAddMatchInStageClicked"
                            IsVisible="{Binding SelectedStage, Converter={StaticResource NotNullToBool}}" />
                    <CollectionView ItemsSource="{Binding StageMatches}"
                                    IsVisible="{Binding SelectedStage, Converter={StaticResource NotNullToBool}}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid RowDefinitions="Auto,Auto,Auto" Padding="0,6">
                                    <Label FontSize="12"
                                           Text="{Binding DateTime, StringFormat='{}{0:dd.MM HH:mm}'}" />
                                    <Label Grid.Row="1" FontSize="14">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} – {1}  {2}">
                                                <Binding Path="HomeTeamName" />
                                                <Binding Path="AwayTeamName" />
                                                <Binding Path="DisplayScore" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Button Grid.Row="2"
                                            Text="Редактировать матч"
                                            Clicked="OnFinishMatchClicked" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Вкладка Участники -->
                <VerticalStackLayout IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IndexEqualsToBool}, ConverterParameter=2}" Spacing="16">
                    <Button Text="{x:Static res:AppResources.AddTeam}"
                            Clicked="OnAddParticipantClicked" />
                    <CollectionView ItemsSource="{Binding ParticipantTeams}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="{x:Static res:AppResources.Delete}"
                                                       BackgroundColor="Red"
                                                       Invoked="OnDeleteParticipantInvoked" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Frame Margin="12,6" Padding="12" HasShadow="True" CornerRadius="8">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnParticipantTapped" />
                                        </Frame.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                            <Image Grid.Column="0"
                                                   WidthRequest="40" HeightRequest="40"
                                                   Source="{Binding IconPath, Converter={StaticResource PathToImageSource}}"
                                                   Aspect="AspectFill" />
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                                                <Label Text="{Binding ShortName}" FontSize="12" TextColor="Gray" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Frame>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Вкладка Статистика -->
                <VerticalStackLayout IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IndexEqualsToBool}, ConverterParameter=3}" Spacing="12">
                    <Label Text="{x:Static res:AppResources.TabStatistics}"
                           FontAttributes="Bold"
                           FontSize="18" />
                    <Label Text="{x:Static res:AppResources.StatisticsTabHint}"
                           FontSize="13"
                           TextColor="Gray" />
                    <Button Text="{x:Static res:AppResources.OpenStatistics}"
                            Clicked="OnOpenStatisticsClicked" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Нижняя панель вкладок: полностью своя разметка без стилей Button,
             чтобы текст не обрезался и был виден в любой теме -->
        <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="{StaticResource Gray200Brush}" Padding="0,4">
            <Grid ColumnDefinitions="*,*,*,*" VerticalOptions="Center" HeightRequest="64">
                <!-- Главная -->
                <VerticalStackLayout Grid.Column="0"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center"
                                      Spacing="2">
                    <Image WidthRequest="28" HeightRequest="28"
                           Source="{Binding HomeTabIcon, Converter={StaticResource MauiImageAliasToImageSource}}"
                           VerticalOptions="Center" />
                    <Label Text="{x:Static res:AppResources.TabHome}"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabHomeClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <!-- Стадии -->
                <VerticalStackLayout Grid.Column="1"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center"
                                      Spacing="2">
                    <Image WidthRequest="28" HeightRequest="28"
                           Source="{Binding StagesTabIcon, Converter={StaticResource MauiImageAliasToImageSource}}"
                           VerticalOptions="Center" />
                    <Label Text="{x:Static res:AppResources.TabStages}"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabStagesClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <!-- Участники -->
                <VerticalStackLayout Grid.Column="2"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center"
                                      Spacing="2">
                    <Image WidthRequest="28" HeightRequest="28"
                           Source="{Binding ParticipantsTabIcon, Converter={StaticResource MauiImageAliasToImageSource}}"
                           VerticalOptions="Center" />
                    <Label Text="{x:Static res:AppResources.TabParticipants}"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabParticipantsClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <!-- Статистика -->
                <VerticalStackLayout Grid.Column="3"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center"
                                      Spacing="2">
                    <Label Text="▣"
                           FontSize="20"
                           HorizontalTextAlignment="Center"
                           TextColor="{Binding StatisticsTabLabelColorHex, Converter={StaticResource HexColorToColor}}" />
                    <Label Text="{x:Static res:AppResources.TabStatistics}"
                           FontSize="11"
                           HorizontalTextAlignment="Center"
                           TextColor="{Binding StatisticsTabLabelColorHex, Converter={StaticResource HexColorToColor}}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabStatisticsClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
