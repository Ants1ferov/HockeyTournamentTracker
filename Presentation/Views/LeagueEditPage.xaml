<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HockeyTournamentTracker.Presentation.ViewModels"
             x:Class="HockeyTournamentTracker.Presentation.Views.LeagueEditPage"
             Title="Лига">

    <ScrollView>
        <StackLayout Padding="16" Spacing="12">

            <Label Text="Название" FontAttributes="Bold" />
            <Entry Text="{Binding Name}"
                   Placeholder="Название лиги" />

            <Label Text="Вид спорта" FontAttributes="Bold" />
            <Entry Text="{Binding Sport}"
                   Placeholder="Например: хоккей" />

            <Label Text="Описание" FontAttributes="Bold" />
            <Editor Text="{Binding Description}"
                    Placeholder="Описание (необязательно)"
                    HeightRequest="80" />

            <Label Text="Турниры в лиге"
                   FontAttributes="Bold"
                   Margin="0,8,0,0" />

            <CollectionView ItemsSource="{Binding TournamentItems}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,6"
                              ColumnDefinitions="Auto,*">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsSelected}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Tournament.Name}"
                                   VerticalOptions="Center"
                                   FontSize="15" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Сохранить"
                    Clicked="OnSaveClicked"
                    Margin="0,16,0,0" />

        </StackLayout>
    </ScrollView>

</ContentPage>
