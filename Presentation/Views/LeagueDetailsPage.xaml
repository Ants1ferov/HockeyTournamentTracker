<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HockeyTournamentTracker.Presentation.ViewModels"
             x:Class="HockeyTournamentTracker.Presentation.Views.LeagueDetailsPage"
             Title="{Binding LeagueName}">

    <Grid RowDefinitions="Auto,*">
        <!-- Красная шапка -->
        <Grid Grid.Row="0"
              BackgroundColor="{AppThemeBinding Light={StaticResource Brand}, Dark={StaticResource BrandDark}}"
              Padding="16,12">
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding LeagueName}"
                       TextColor="{StaticResource OnBrand}"
                       FontSize="22"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="Изменить"
                        Style="{StaticResource GhostButtonStyle}"
                        TextColor="{StaticResource OnBrand}"
                        BorderColor="Transparent"
                        Clicked="OnEditLeagueClicked" />
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1">
            <StackLayout Padding="16,8" Spacing="8">
                <Button Text="+ Добавить турнир в лигу"
                        Clicked="OnAddTournamentClicked"
                        Margin="0,4,0,8" />

                <Label Text="Турниры лиги"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,4,0,0" />

                <CollectionView ItemsSource="{Binding Tournaments}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardElevatedStyle}"
                                    Margin="0,4">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTournamentTapped" />
                                </Border.GestureRecognizers>
                                <Grid Padding="12,10"
                                      RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="*,Auto">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontAttributes="Bold"
                                           FontSize="16" />
                                    <Border Grid.Row="0" Grid.Column="1"
                                            Style="{StaticResource StatusBadgeStyle}"
                                            BackgroundColor="{Binding Status, Converter={StaticResource StatusToBadgeColor}}"
                                            VerticalOptions="Center">
                                        <Label Text="{Binding Status, Converter={StaticResource TournamentStatusToString}}"
                                               TextColor="{Binding Status, Converter={StaticResource StatusToBadgeTextColor}}"
                                               FontSize="11" />
                                    </Border>
                                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0:d} — {1:d}">
                                                <Binding Path="StartDate" />
                                                <Binding Path="EndDate" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </StackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
