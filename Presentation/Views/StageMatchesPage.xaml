<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.StageMatchesPage"
             Title="{x:Static res:AppResources.Matches}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Button Text="{x:Static res:AppResources.AddMatch}"
                    Clicked="OnAddMatchClicked" />

            <CollectionView ItemsSource="{Binding StageMatches}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,4"
                               Padding="12"
                               HasShadow="True"
                               CornerRadius="8">
                            <VerticalStackLayout Spacing="8">
                                <Label FontSize="12"
                                       Text="{Binding DateTime, StringFormat='{}{0:dd.MM HH:mm}'}" />
                                <Label FontSize="14">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0} – {1}  {2}">
                                            <Binding Path="HomeTeamName" />
                                            <Binding Path="AwayTeamName" />
                                            <Binding Path="DisplayScore" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
                                      ColumnSpacing="8">
                                    <Button Grid.Column="0"
                                            Text="{x:Static res:AppResources.StartMatch}"
                                            IsVisible="{Binding Status, Converter={StaticResource MatchStatusToStartVisible}}"
                                            Clicked="OnStartMatchClicked" />
                                    <Button Grid.Column="1"
                                            Text="{x:Static res:AppResources.FinishMatch}"
                                            IsVisible="{Binding IsLive}"
                                            Clicked="OnFinishMatchClicked" />
                                    <Button Grid.Column="2"
                                            Text="Редактировать"
                                            Clicked="OnEditMatchClicked" />
                                    <Button Grid.Column="3"
                                            Text="{x:Static res:AppResources.Delete}"
                                            Clicked="OnDeleteMatchClicked" />
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
