<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.StageMatchesPage"
             Title="{x:Static res:AppResources.Matches}">

    <Grid RowDefinitions="Auto,*"
          RowSpacing="8">
        <VerticalStackLayout Grid.Row="0"
                             Padding="16,12,16,0"
                             Spacing="10">
            <Button Text="{x:Static res:AppResources.AddMatch}"
                    Clicked="OnAddMatchClicked" />

            <Label Text="Фильтры"
                   FontAttributes="Bold"
                   FontSize="16" />
            <SearchBar x:Name="TeamSearchBar"
                       Placeholder="Поиск по команде"
                       TextChanged="OnTeamSearchTextChanged" />
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8">
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="4">
                    <Label Text="Период"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                    <Picker x:Name="PeriodFilterPicker"
                            SelectedIndexChanged="OnFilterChanged">
                        <Picker.Items>
                            <x:String>Все</x:String>
                            <x:String>Эта неделя</x:String>
                            <x:String>Этот месяц</x:String>
                            <x:String>Этот год</x:String>
                            <x:String>Последние 30 дней</x:String>
                            <x:String>Произвольный период</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="4">
                    <Label Text="Статус"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                    <Picker x:Name="StatusFilterPicker"
                            SelectedIndexChanged="OnFilterChanged">
                        <Picker.Items>
                            <x:String>Все</x:String>
                            <x:String>Запланирован</x:String>
                            <x:String>В процессе</x:String>
                            <x:String>Завершен</x:String>
                            <x:String>Отменен</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
            </Grid>

            <Grid x:Name="CustomRangePanel"
                  IsVisible="False"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="8">
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="4">
                    <Label Text="С даты"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                    <DatePicker x:Name="FromDatePicker"
                                DateSelected="OnFilterChangedDate" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="4">
                    <Label Text="По дату"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                    <DatePicker x:Name="ToDatePicker"
                                DateSelected="OnFilterChangedDate" />
                </VerticalStackLayout>
            </Grid>

            <HorizontalStackLayout Spacing="8">
                <Button Text="Сбросить фильтры"
                        Clicked="OnResetFiltersClicked" />
                <Label x:Name="MatchesCounterLabel"
                       VerticalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="MatchesCollection"
                        Margin="16,0,16,8"
                        RemainingItemsThreshold="5"
                        RemainingItemsThresholdReached="OnRemainingItemsThresholdReached">
            <CollectionView.Footer>
                <VerticalStackLayout Padding="0,8,0,16"
                                     Spacing="8">
                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsVisible="False"
                                       IsRunning="False" />
                    <Button x:Name="LoadMoreButton"
                            Text="Показать еще"
                            IsVisible="False"
                            Clicked="OnLoadMoreClicked" />
                </VerticalStackLayout>
            </CollectionView.Footer>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,4"
                            Padding="12"
                            Style="{StaticResource CardElevatedStyle}">
                        <VerticalStackLayout Spacing="8">
                            <!-- Верхняя строка: дата + статус-бейдж -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       FontSize="12"
                                       Text="{Binding DateTime, StringFormat='{}{0:dd.MM HH:mm}'}"
                                       TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"
                                       VerticalTextAlignment="Center" />
                                <Border Grid.Column="1"
                                        Style="{StaticResource StatusBadgeStyle}"
                                        BackgroundColor="{Binding Status, Converter={StaticResource MatchStatusBadgeColor}}"
                                        IsVisible="{Binding Status, Converter={StaticResource MatchStatusBadgeVisible}}">
                                    <Label Text="{Binding Status, Converter={StaticResource MatchStatusToText}}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{Binding Status, Converter={StaticResource MatchStatusBadgeTextColor}}" />
                                </Border>
                            </Grid>
                            <!-- Центр: хозяева | счёт | гости -->
                            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                                <Label Grid.Column="0"
                                       Text="{Binding HomeTeamName}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding DisplayScore}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Column="2"
                                       Text="{Binding AwayTeamName}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Start"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                            <!-- Кнопки действий -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Grid.Column="0"
                                        Text="Редактировать"
                                        Clicked="OnEditMatchClicked" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource DangerButton}"
                                        Text="{x:Static res:AppResources.Delete}"
                                        Clicked="OnDeleteMatchClicked" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
