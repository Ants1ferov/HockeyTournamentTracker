<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.StageEditPage"
             Title="{x:Static res:AppResources.AddStage}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{x:Static res:AppResources.GroupName}" />
            <Entry Text="{Binding Name}" Placeholder="" />
            <Label Text="Порядок" />
            <Entry Text="{Binding Order}" Keyboard="Numeric" />
            <Label Text="Тип стадии" />
            <Picker Title="Тип стадии"
                    SelectedIndex="{Binding StageTypeIndex}">
                <Picker.Items>
                    <x:String>Швейцарская система</x:String>
                    <x:String>Плей-офф</x:String>
                </Picker.Items>
            </Picker>
            <Button Text="{x:Static res:AppResources.Save}"
                    Margin="0,16,0,0"
                    Clicked="OnSaveClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
