<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.PlayoffBracketPage"
             x:Name="ThisPage"
             Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{Binding PageTitle}"
                   FontAttributes="Bold"
                   FontSize="20" />

            <Frame Padding="12"
                   HasShadow="False"
                   CornerRadius="8"
                   Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Настройки стадии"
                           FontAttributes="Bold"
                           FontSize="16" />
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <Label Text="{x:Static res:AppResources.PlayoffReseedingLabel}"
                               VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding UseReseeding}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <Label Text="Матч за 3-е место"
                               VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding HasThirdPlaceMatch}" />
                    </Grid>
                    <Button Text="Сохранить настройки"
                            Clicked="OnSaveSettingsClicked" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Раунды"
                   FontAttributes="Bold"
                   FontSize="16" />
            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout Spacing="8"
                                       BindableLayout.ItemsSource="{Binding Rounds}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="10,6"
                                   HasShadow="False"
                                   CornerRadius="16"
                                   BorderColor="{AppThemeBinding Light={StaticResource CardBorderLight}, Dark={StaticResource CardBorderDark}}"
                                   BackgroundColor="{AppThemeBinding Light={StaticResource CardSurfaceLight}, Dark={StaticResource CardSurfaceDark}}">
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding IsSelected}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor"
                                                Value="{AppThemeBinding Light={StaticResource SelectionSurfaceLight}, Dark={StaticResource SelectionSurfaceDark}}" />
                                        <Setter Property="BorderColor"
                                                Value="{AppThemeBinding Light={StaticResource SelectionBorderLight}, Dark={StaticResource SelectionBorderDark}}" />
                                    </DataTrigger>
                                </Frame.Triggers>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnRoundChipTapped" />
                                </Frame.GestureRecognizers>
                                <Label Text="{Binding Name}" FontSize="12" />
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8">
                <Button Text="{x:Static res:AppResources.PlayoffAddRound}"
                        Clicked="OnAddRoundClicked" />
                <Button Text="{x:Static res:AppResources.PlayoffAddSeries}"
                        Clicked="OnAddSeriesInSelectedRoundClicked"
                        IsEnabled="{Binding HasSelectedRound}" />
                <Button Text="{x:Static res:AppResources.PlayoffBestOfButton}"
                        Clicked="OnEditSelectedRoundBestOfClicked"
                        IsEnabled="{Binding HasSelectedRound}" />
                <Button Text="{x:Static res:AppResources.PlayoffRenameRound}"
                        Clicked="OnRenameSelectedRoundClicked"
                        IsEnabled="{Binding HasSelectedRound}" />
                <Button Text="{x:Static res:AppResources.Delete}"
                        Clicked="OnDeleteSelectedRoundClicked"
                        IsEnabled="{Binding HasSelectedRound}" />
                </HorizontalStackLayout>
            </ScrollView>

            <Label Text="{Binding SelectedRoundTitle}"
                   FontAttributes="Bold"
                   FontSize="15"
                   IsVisible="{Binding HasSelectedRound}" />
            <CollectionView ItemsSource="{Binding ActiveRoundSeries}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,4"
                               Padding="10"
                               BackgroundColor="{AppThemeBinding Light={StaticResource CardSurfaceMutedLight}, Dark={StaticResource CardSurfaceMutedDark}}"
                               BorderColor="{AppThemeBinding Light={StaticResource CardBorderLight}, Dark={StaticResource CardBorderDark}}"
                               HasShadow="False"
                               CornerRadius="8">
                            <Frame.GestureRecognizers>
                                <DragGestureRecognizer DragStarting="OnSeriesDragStarting" />
                                <DropGestureRecognizer AllowDrop="True"
                                                       DragOver="OnSeriesDragOver"
                                                       Drop="OnSeriesDrop" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <Label Grid.Column="0"
                                           Text="{Binding Title}"
                                           FontAttributes="Bold"
                                           FontSize="13" />
                                    <Label Grid.Column="1"
                                           Text="{Binding EffectiveBestOf, StringFormat='Bo{0}'}"
                                           FontSize="11"
                                           TextColor="{AppThemeBinding Light=#991B1B, Dark=#FCA5A5}" />
                                </Grid>
                                <Label Text="{Binding ScoreText}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                                <Label Text="{Binding WinnerText}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#166534, Dark=#86EFAC}"
                                       IsVisible="{Binding WinnerText, Converter={StaticResource GroupNameToVisibility}}" />
                                <Grid ColumnDefinitions="*,*"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="6"
                                      RowSpacing="6">
                                    <Button Grid.Row="0"
                                            Grid.Column="0"
                                            Text="Редактировать"
                                            Clicked="OnEditSeriesClicked" />
                                    <Button Grid.Row="0"
                                            Grid.Column="1"
                                            Text="+ Матч"
                                            Clicked="OnAddSeriesMatchClicked" />
                                    <Button Grid.Row="1"
                                            Grid.Column="0"
                                            Text="Матчи серии"
                                            Clicked="OnOpenSeriesMatchesClicked" />
                                    <Button Grid.Row="1"
                                            Grid.Column="1"
                                            Text="{x:Static res:AppResources.Delete}"
                                            Clicked="OnDeleteSeriesClicked" />
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Схема сетки"
                   FontAttributes="Bold"
                   FontSize="16"
                   Margin="0,8,0,0" />
            <Label Text="{x:Static res:AppResources.PlayoffReseedingHint}"
                   FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}"
                   IsVisible="{Binding UseReseeding}" />
            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Default">
                <HorizontalStackLayout Spacing="10"
                                       BindableLayout.ItemsSource="{Binding Rounds}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Grid WidthRequest="224"
                                  RowDefinitions="Auto,*">
                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       FontSize="12"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource SelectionSurfaceLight}, Dark={StaticResource SelectionSurfaceDark}}"
                                       TextColor="{AppThemeBinding Light=#7F1D1D, Dark=#FCA5A5}"
                                       Padding="6,2"
                                       Margin="0,0,0,6"
                                       HorizontalOptions="Start"
                                       VerticalOptions="Start" />

                                <AbsoluteLayout Grid.Row="1"
                                                HeightRequest="{Binding CanvasHeight}"
                                                InputTransparent="True"
                                                BindableLayout.ItemsSource="{Binding ConnectorSegments}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <BoxView Color="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray500}}"
                                                     AbsoluteLayout.LayoutBounds="{Binding Bounds}"
                                                     AbsoluteLayout.LayoutFlags="None" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </AbsoluteLayout>

                                <AbsoluteLayout Grid.Row="1"
                                                HeightRequest="{Binding CanvasHeight}"
                                                BindableLayout.ItemsSource="{Binding Series}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Frame Padding="8"
                                                   CornerRadius="8"
                                                   HasShadow="False"
                                                   BorderColor="{AppThemeBinding Light={StaticResource CardBorderLight}, Dark={StaticResource CardBorderDark}}"
                                                   BackgroundColor="{AppThemeBinding Light={StaticResource CardSurfaceLight}, Dark={StaticResource CardSurfaceDark}}"
                                                   AbsoluteLayout.LayoutBounds="{Binding BracketBounds}"
                                                   AbsoluteLayout.LayoutFlags="None">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{Binding HomeTeamName}"
                                                           FontSize="11"
                                                           MaxLines="1"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding AwayTeamName}"
                                                           FontSize="11"
                                                           MaxLines="1"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding ScoreText}"
                                                           FontSize="10"
                                                           MaxLines="1"
                                                           LineBreakMode="TailTruncation"
                                                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                                                </VerticalStackLayout>
                                            </Frame>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </AbsoluteLayout>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
