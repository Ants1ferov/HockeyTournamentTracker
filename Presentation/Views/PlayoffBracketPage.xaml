<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.Presentation.Views.PlayoffBracketPage"
             x:Name="ThisPage"
             Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{Binding PageTitle}"
                   FontAttributes="Bold"
                   FontSize="20" />

            <Frame Padding="12"
                   HasShadow="True"
                   CornerRadius="8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Настройки стадии"
                           FontAttributes="Bold"
                           FontSize="16" />
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <Label Text="{x:Static res:AppResources.PlayoffReseedingLabel}"
                               VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding UseReseeding}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <Label Text="Матч за 3-е место"
                               VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding HasThirdPlaceMatch}" />
                    </Grid>
                    <Button Text="Сохранить настройки"
                            Clicked="OnSaveSettingsClicked" />
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="12"
                   HasShadow="True"
                   CornerRadius="8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Автозаполнение"
                           FontAttributes="Bold"
                           FontSize="16" />
                    <Picker x:Name="SeedSourceStagePicker"
                            Title="Источник посева"
                            ItemsSource="{Binding SeedSourceStages}"
                            ItemDisplayBinding="{Binding Name}" />
                    <Button Text="Заполнить первый раунд по посеву"
                            Clicked="OnAutoFillSeedClicked" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Раунды"
                   FontAttributes="Bold"
                   FontSize="16" />
            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout Spacing="8"
                                       BindableLayout.ItemsSource="{Binding Rounds}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="10,6"
                                   HasShadow="False"
                                   CornerRadius="16"
                                   BorderColor="#D1D5DB"
                                   BackgroundColor="White">
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding IsSelected}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor"
                                                Value="#FEE2E2" />
                                        <Setter Property="BorderColor"
                                                Value="#DC2626" />
                                    </DataTrigger>
                                </Frame.Triggers>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnRoundChipTapped" />
                                </Frame.GestureRecognizers>
                                <Label Text="{Binding Name}" FontSize="12" />
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8">
                <Button Text="{x:Static res:AppResources.PlayoffAddRound}"
                        Clicked="OnAddRoundClicked" />
                <Button Text="{x:Static res:AppResources.PlayoffAddSeries}"
                        Clicked="OnAddSeriesInSelectedRoundClicked"
                        IsEnabled="{Binding HasSelectedRound}" />
                <Button Text="{x:Static res:AppResources.PlayoffBestOfButton}"
                        Clicked="OnEditSelectedRoundBestOfClicked"
                        IsEnabled="{Binding HasSelectedRound}" />
                <Button Text="{x:Static res:AppResources.PlayoffRenameRound}"
                        Clicked="OnRenameSelectedRoundClicked"
                        IsEnabled="{Binding HasSelectedRound}" />
                <Button Text="{x:Static res:AppResources.Delete}"
                        Clicked="OnDeleteSelectedRoundClicked"
                        IsEnabled="{Binding HasSelectedRound}" />
                </HorizontalStackLayout>
            </ScrollView>

            <Label Text="{Binding SelectedRoundTitle}"
                   FontAttributes="Bold"
                   FontSize="15"
                   IsVisible="{Binding HasSelectedRound}" />
            <CollectionView ItemsSource="{Binding ActiveRoundSeries}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,4"
                               Padding="10"
                               BackgroundColor="#F3F4F6"
                               HasShadow="False"
                               CornerRadius="8">
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <Label Grid.Column="0"
                                           Text="{Binding Title}"
                                           FontAttributes="Bold"
                                           FontSize="13" />
                                    <Label Grid.Column="1"
                                           Text="{Binding EffectiveBestOf, StringFormat='Bo{0}'}"
                                           FontSize="11"
                                           TextColor="#991B1B" />
                                </Grid>
                                <Label Text="{Binding ScoreText}"
                                       FontSize="12"
                                       TextColor="Gray" />
                                <Label Text="{Binding WinnerText}"
                                       FontSize="12"
                                       TextColor="#166534"
                                       IsVisible="{Binding WinnerText, Converter={StaticResource GroupNameToVisibility}}" />
                                <HorizontalStackLayout Spacing="6">
                                    <Button Text="Редактировать"
                                            Clicked="OnEditSeriesClicked" />
                                    <Button Text="+ Матч"
                                            Clicked="OnAddSeriesMatchClicked" />
                                    <Button Text="Матчи серии"
                                            Clicked="OnOpenSeriesMatchesClicked" />
                                    <Button Text="{x:Static res:AppResources.Delete}"
                                            Clicked="OnDeleteSeriesClicked" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Схема сетки"
                   FontAttributes="Bold"
                   FontSize="16"
                   Margin="0,8,0,0" />
            <Label Text="{x:Static res:AppResources.PlayoffReseedingHint}"
                   FontSize="11"
                   TextColor="Gray"
                   IsVisible="{Binding UseReseeding}" />
            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Default">
                <HorizontalStackLayout Spacing="10"
                                       BindableLayout.ItemsSource="{Binding Rounds}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Grid WidthRequest="224"
                                  HeightRequest="{Binding CanvasHeight}">
                                <AbsoluteLayout InputTransparent="True"
                                                BindableLayout.ItemsSource="{Binding ConnectorSegments}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <BoxView Color="#D1D5DB"
                                                     AbsoluteLayout.LayoutBounds="{Binding Bounds}"
                                                     AbsoluteLayout.LayoutFlags="None" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </AbsoluteLayout>

                                <AbsoluteLayout BindableLayout.ItemsSource="{Binding Series}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Frame Padding="8"
                                                   CornerRadius="8"
                                                   HasShadow="False"
                                                   BorderColor="#D1D5DB"
                                                   BackgroundColor="White"
                                                   AbsoluteLayout.LayoutBounds="{Binding BracketBounds}"
                                                   AbsoluteLayout.LayoutFlags="None">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{Binding HomeTeamName}"
                                                           FontSize="12"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding AwayTeamName}"
                                                           FontSize="12"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding ScoreText}"
                                                           FontSize="10"
                                                           TextColor="Gray" />
                                                </VerticalStackLayout>
                                            </Frame>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </AbsoluteLayout>

                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       FontSize="12"
                                       BackgroundColor="#FEE2E2"
                                       TextColor="#7F1D1D"
                                       Padding="6,2"
                                       Margin="0,-2,0,0"
                                       HorizontalOptions="Start"
                                       VerticalOptions="Start" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
