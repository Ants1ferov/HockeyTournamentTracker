<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:HockeyTournamentTracker"
             xmlns:converters="clr-namespace:HockeyTournamentTracker.Presentation.Converters"
             x:Class="HockeyTournamentTracker.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:TournamentStatusToStringConverter x:Key="TournamentStatusToString" />
            <converters:PathToImageSourceConverter x:Key="PathToImageSource" />
            <converters:MatchStatusToStartButtonVisibleConverter x:Key="MatchStatusToStartVisible" />
            <converters:LastResultToColorConverter x:Key="LastResultToColor" />
            <converters:StandingSortCriterionToStringConverter x:Key="StandingSortCriterionToString" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
