<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>
    <Color x:Key="TableCellLight">#FFFFFF</Color>
    <Color x:Key="TableCellAltLight">#F3F4F6</Color>
    <Color x:Key="TableHeaderAltLight">#E5E7EB</Color>
    <Color x:Key="TableCellDark">#1F2937</Color>
    <Color x:Key="TableCellAltDark">#111827</Color>
    <Color x:Key="TableHeaderAltDark">#374151</Color>
    <Color x:Key="CardSurfaceLight">#FFFFFF</Color>
    <Color x:Key="CardSurfaceDark">#1F2937</Color>
    <Color x:Key="CardSurfaceMutedLight">#F9FAFB</Color>
    <Color x:Key="CardSurfaceMutedDark">#111827</Color>
    <Color x:Key="CardBorderLight">#E5E7EB</Color>
    <Color x:Key="CardBorderDark">#374151</Color>
    <Color x:Key="SecondaryTextLight">#6E6E6E</Color>
    <Color x:Key="SecondaryTextDark">#C8C8C8</Color>
    <Color x:Key="SelectionSurfaceLight">#E5E7EB</Color>
    <Color x:Key="SelectionSurfaceDark">#374151</Color>
    <Color x:Key="SelectionBorderLight">#6B7280</Color>
    <Color x:Key="SelectionBorderDark">#9CA3AF</Color>

    <!-- Бренд-красный -->
    <Color x:Key="Brand">#E2231A</Color>
    <Color x:Key="BrandPressed">#B71C15</Color>
    <Color x:Key="BrandDark">#F0524B</Color>
    <Color x:Key="BrandSurface">#FCE9E8</Color>
    <Color x:Key="BrandSurfaceDark">#3A1413</Color>
    <Color x:Key="OnBrand">#FFFFFF</Color>

    <!-- Статусы матчей и турниров -->
    <Color x:Key="StatusLive">#1D9E75</Color>
    <Color x:Key="StatusLiveSurface">#E1F5EE</Color>
    <Color x:Key="StatusLiveSurfaceDark">#0F3A2E</Color>
    <Color x:Key="StatusFinished">#6E6E6E</Color>
    <Color x:Key="StatusFinishedSurface">#EFEFEF</Color>
    <Color x:Key="StatusFinishedSurfaceDark">#2A2A2A</Color>
    <Color x:Key="StatusPlanned">#BA7517</Color>
    <Color x:Key="StatusPlannedSurface">#FAEEDA</Color>
    <Color x:Key="StatusPlannedSurfaceDark">#3D2A0C</Color>

    <!-- Зоны турнирной таблицы -->
    <Color x:Key="ZonePlayoff">#1D9E75</Color>
    <Color x:Key="ZonePlayIn">#BA7517</Color>
    <Color x:Key="ZoneOut">#E24B4A</Color>
    <Color x:Key="ZoneNeutral">#C8C8C8</Color>

    <SolidColorBrush x:Key="BrandBrush" Color="{StaticResource Brand}"/>
    <SolidColorBrush x:Key="BrandPressedBrush" Color="{StaticResource BrandPressed}"/>
    <SolidColorBrush x:Key="OnBrandBrush" Color="{StaticResource OnBrand}"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>