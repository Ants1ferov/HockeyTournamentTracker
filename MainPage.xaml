<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.MainPage"
             Title="{x:Static res:AppResources.TabTournaments}">

    <Grid RowDefinitions="Auto,*">
        <HorizontalStackLayout Padding="16,8" Spacing="12">
            <Label Text="{x:Static res:AppResources.MyTournaments}"
                   FontSize="20"
                   HorizontalOptions="StartAndExpand" />
            <Button Text="{x:Static res:AppResources.Add}"
                    Clicked="OnAddTournamentClicked" />
        </HorizontalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Tournaments}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="{x:Static res:AppResources.Delete}"
                                           BackgroundColor="Red"
                                           Invoked="OnDeleteTournamentInvoked" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Frame Margin="12,6"
                               Padding="12"
                               HasShadow="True"
                               CornerRadius="8"
                               MinimumHeightRequest="56">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTournamentTapped" />
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="*,Auto">
                                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       FontSize="18" />
                                <Label Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding Status, Converter={StaticResource TournamentStatusToString}}"
                                       FontSize="12"
                                       TextColor="Gray"
                                       VerticalOptions="Center" />

                                <Label Grid.Row="1"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       FontSize="12"
                                       TextColor="Gray">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0:d} — {1:d}">
                                            <Binding Path="StartDate" />
                                            <Binding Path="EndDate" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
