<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:HockeyTournamentTracker.Resources"
             x:Class="HockeyTournamentTracker.MainPage"
             Title="{x:Static res:AppResources.TabTournaments}">

    <ContentPage.Resources>
        <!-- Переиспользуемая строка турнира (внутри лиги и в секции «без лиги») -->
        <DataTemplate x:Key="TournamentRowTemplate">
            <Border Style="{StaticResource CardElevatedStyle}"
                    Margin="12,4">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTournamentTapped" />
                </Border.GestureRecognizers>
                <Grid Padding="12,10"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="10">
                    <!-- Квадрат сезона -->
                    <Border Grid.Column="0"
                            WidthRequest="40" HeightRequest="40"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}"
                            VerticalOptions="Center">
                        <Label Text="{Binding SeasonLabel}"
                               FontSize="12"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="{Binding Name}"
                               FontAttributes="Bold"
                               FontSize="16" />
                        <Label Text="{Binding SubtitleLine}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                    </VerticalStackLayout>
                    <!-- Бейдж live -->
                    <Border Grid.Column="2"
                            Style="{StaticResource StatusBadgeStyle}"
                            VerticalOptions="Center"
                            IsVisible="{Binding IsLive}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource StatusLiveSurface}, Dark={StaticResource StatusLiveSurfaceDark}}">
                        <Label Text="live"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="{StaticResource StatusLive}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </ContentPage.Resources>

    <ScrollView>
        <StackLayout Padding="0,0,0,24">

            <!-- Шапка с темой -->
            <Grid Padding="16,12,16,8" ColumnDefinitions="*,Auto">
                <Picker x:Name="ThemePicker"
                        Grid.Column="1"
                        Title="{x:Static res:AppResources.Theme}"
                        WidthRequest="130"
                        SelectedIndexChanged="OnThemeChanged" />
            </Grid>

            <!-- Секция Лиги -->
            <Grid Padding="16,0,16,4" ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="Мои лиги"
                       FontSize="20"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="+ Создать"
                        Clicked="OnAddLeagueClicked" />
            </Grid>

            <CollectionView ItemsSource="{Binding Leagues}"
                            SelectionMode="None"
                            Margin="0,0,0,8">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView Margin="12,4">
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Изменить"
                                               BackgroundColor="{StaticResource Brand}"
                                               Invoked="OnEditLeagueInvoked" />
                                    <SwipeItem Text="Удалить"
                                               BackgroundColor="{StaticResource ZoneOut}"
                                               Invoked="OnDeleteLeagueInvoked" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Style="{StaticResource CardElevatedStyle}"
                                    Padding="0">
                                <VerticalStackLayout Spacing="0">
                                    <!-- Красная плашка-заголовок лиги -->
                                    <Grid Padding="12,10"
                                          ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="10"
                                          BackgroundColor="{AppThemeBinding Light={StaticResource Brand}, Dark={StaticResource BrandDark}}">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnLeagueTapped" />
                                        </Grid.GestureRecognizers>
                                        <Border Grid.Column="0"
                                                WidthRequest="40" HeightRequest="40"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                BackgroundColor="#33000000"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding Initial}"
                                                   TextColor="{StaticResource OnBrand}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   FontAttributes="Bold"
                                                   FontSize="14" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   TextColor="{StaticResource OnBrand}"
                                                   FontAttributes="Bold"
                                                   FontSize="16" />
                                            <Label Text="{Binding Subtitle}"
                                                   TextColor="{StaticResource OnBrand}"
                                                   Opacity="0.85"
                                                   FontSize="12" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2"
                                               Text="⌄"
                                               TextColor="{StaticResource OnBrand}"
                                               FontSize="18"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <!-- Вложенные турниры лиги -->
                                    <VerticalStackLayout Spacing="0"
                                                         Padding="0,4,0,8"
                                                         IsVisible="{Binding IsExpanded}"
                                                         BindableLayout.ItemsSource="{Binding Tournaments}"
                                                         BindableLayout.ItemTemplate="{StaticResource TournamentRowTemplate}" />
                                </VerticalStackLayout>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Секция Турниры (без лиги) -->
            <Grid Padding="16,8,16,4" ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="Мои турниры"
                       FontSize="20"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="+ Создать"
                        Clicked="OnAddTournamentClicked" />
            </Grid>

            <CollectionView ItemsSource="{Binding TournamentsWithoutLeague}"
                            SelectionMode="None"
                            Margin="0,0,0,8">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="{x:Static res:AppResources.Delete}"
                                               BackgroundColor="{StaticResource ZoneOut}"
                                               Invoked="OnDeleteTournamentInvoked" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Style="{StaticResource CardElevatedStyle}"
                                    Margin="12,4">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTournamentTapped" />
                                </Border.GestureRecognizers>
                                <Grid Padding="12,10"
                                      ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="10">
                                    <Border Grid.Column="0"
                                            WidthRequest="40" HeightRequest="40"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}"
                                            VerticalOptions="Center">
                                        <Label Text="{Binding SeasonLabel}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               FontSize="16" />
                                        <Label Text="{Binding SubtitleLine}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                                    </VerticalStackLayout>
                                    <Border Grid.Column="2"
                                            Style="{StaticResource StatusBadgeStyle}"
                                            VerticalOptions="Center"
                                            IsVisible="{Binding IsLive}"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource StatusLiveSurface}, Dark={StaticResource StatusLiveSurfaceDark}}">
                                        <Label Text="live"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource StatusLive}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </StackLayout>
    </ScrollView>

</ContentPage>
