<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HockeyTournamentTracker.MainPage"
             Title="Турниры">

    <Grid RowDefinitions="Auto,*">
        <HorizontalStackLayout Padding="16,8" Spacing="12">
            <Label Text="Мои хоккейные турниры"
                   FontSize="20"
                   HorizontalOptions="StartAndExpand" />
            <Button Text="Добавить"
                    Clicked="OnAddTournamentClicked" />
        </HorizontalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Tournaments}"
                        SelectionMode="Single"
                        SelectionChanged="OnTournamentSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="12,6"
                           Padding="12"
                           HasShadow="True"
                           CornerRadius="8">
                        <Grid RowDefinitions="Auto,Auto"
                              ColumnDefinitions="*,Auto">
                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontAttributes="Bold"
                                   FontSize="18" />
                            <Label Grid.Row="0"
                                   Grid.Column="1"
                                   Text="{Binding Status}"
                                   FontSize="12"
                                   TextColor="Gray" />

                            <Label Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   FontSize="12"
                                   TextColor="Gray">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0:d} — {1:d}">
                                        <Binding Path="StartDate" />
                                        <Binding Path="EndDate" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
